/*---
compatibilityVersion: naiscript-1.0
id: secret-info-panel
name: Secret Info Panel
createdAt: 1742860800000
updatedAt: 1774396800000
version: 1.4.21a
author: Glyph
description: Sidebar-first secret information continuity panel with split prompt fields, separate current output/runtime state, same-turn seed protection, body-only secret-info editing, lightweight canonicalization, and ephemeral edit drafts.
memoryLimit: 32
---*/

const PANEL_ID = "secret-info-panel";
const PANEL_NAME = "Secret Info";
const PANEL_ICON: IconId = "eye-off";

const PROMPT_FIELDS_KEY = "secret-info-panel-prompt-fields-v1";
const CURRENT_OUTPUT_KEY = "secret-info-panel-current-output-v1";
const GENERATED_STATE_KEY = "secret-info-panel-generated-state-v1";
const PROMPT_PREVIEW_KEY = "secret-info-panel-prompt-preview-v1";

const TEMP_ACTIVE_EDIT_FIELD_KEY = "secret-info-panel-temp-active-edit-field-v1";
const TEMP_SECRET_INFO_DRAFT_KEY = "secret-info-panel-temp-secret-info-draft-v1";
const TEMP_SYSTEM_PROMPT_DRAFT_KEY = "secret-info-panel-temp-system-prompt-draft-v1";
const TEMP_SCRIPT_PROMPT_DRAFT_KEY = "secret-info-panel-temp-script-prompt-draft-v1";

const RECENT_HISTORY_UI_KEYS = [
  "recent-history-slot-0",
  "recent-history-slot-1",
  "recent-history-slot-2",
  "recent-history-slot-3",
] as const;

const DEFAULT_SECRET_INFO_LABEL = "Secret information";
const SECRET_INFO_PREFIX = `${DEFAULT_SECRET_INFO_LABEL}:`;
const DEFAULT_MAX_HISTORY_ENTRIES = 40;
const RECENT_HISTORY_VISIBLE_COUNT = 4;
const STORY_CONTEXT_SECTION_LIMIT = 14;
const STORY_CONTEXT_CHAR_LIMIT = 12000;
const SECRET_INFO_MAX_TOKENS = 180;

const DEFAULT_SCRIPT_SYSTEM_PROMPT = `You generate a private secret information continuity block for an ongoing fictional story.

Return exactly one compact paragraph.
Keep the tone close-third, soft, uncertain, interior, and low-drama.
Avoid rigid structure, bullet points, JSON, planning language, and omniscient certainty.
Avoid recursive escalation.
Do not make highly certain claims about motives or psychology unless the story strongly supports them.
Begin the output with \"${SECRET_INFO_PREFIX}\" followed by the paragraph.`;

const DEFAULT_SCRIPT_PROMPT = `Using the live story context and the prior secret-information seed block, write one updated private secret-information paragraph for continuity tracking.

Requirements:
- one compact paragraph only
- close third person
- uncertain, interior, low-drama language
- preserve continuity with the prior seed when appropriate
- do not overfit into rigid schemas
- do not write public summary language
- do not include explanation before or after the block`;

type EditField = "secretInfo" | "scriptSystemPrompt" | "scriptPrompt" | null;

type PromptFieldsState = {
  scriptSystemPrompt: string;
  scriptPrompt: string;
  maxHistoryEntries: number;
  autoRefreshEachTurn: boolean;
  useAuthorsNoteForSecretInfo: boolean;
  lorebookOnlyCharacterDetection: boolean;
  secretInfoLabel: string;
};

type CurrentOutputState = {
  secretInfo: string;
};

type HistoryLogEntry = {
  sequence: number;
  timestamp: string;
  nodeId: string;
  storyTurnCounter: number;
  headerStatus: "changed" | "unchanged";
  secretInfo: string;
};

type GeneratedState = {
  lastUpdatedAt: string;
  lastModel: string;
  lastStatus: string;
  lastError: string;
  lastStoryTitle: string;
  lastPromptDynamic: string;
  lastRawResponse: string;
  logEntries: HistoryLogEntry[];
  nextLogSequence: number;
  storyTurnCounter: number;
  promptSeedTurnCounter: number;
  promptSeedSecretInfo: string;
  lastObservedHistoryNodeId: string;
};

type PromptPreviewState = {
  promptPreview: string;
};

let isInitialized = false;
let isProcessing = false;
let isInternalSecretInfoGeneration = false;

function createDefaultPromptFieldsState(): PromptFieldsState {
  return {
    scriptSystemPrompt: DEFAULT_SCRIPT_SYSTEM_PROMPT,
    scriptPrompt: DEFAULT_SCRIPT_PROMPT,
    maxHistoryEntries: DEFAULT_MAX_HISTORY_ENTRIES,
    autoRefreshEachTurn: false,
    useAuthorsNoteForSecretInfo: false,
    lorebookOnlyCharacterDetection: false,
    secretInfoLabel: DEFAULT_SECRET_INFO_LABEL,
  };
}

function createDefaultCurrentOutputState(): CurrentOutputState {
  return {
    secretInfo: "",
  };
}

function createDefaultGeneratedState(): GeneratedState {
  return {
    lastUpdatedAt: "",
    lastModel: "",
    lastStatus: "Idle",
    lastError: "",
    lastStoryTitle: "",
    lastPromptDynamic: "",
    lastRawResponse: "",
    logEntries: [],
    nextLogSequence: 1,
    storyTurnCounter: 0,
    promptSeedTurnCounter: 0,
    promptSeedSecretInfo: "",
    lastObservedHistoryNodeId: "",
  };
}

function createDefaultPromptPreviewState(): PromptPreviewState {
  return {
    promptPreview: "",
  };
}

function sanitizeSecretInfoBody(value: unknown): string {
  const text = typeof value === "string" ? value : "";
  return text
    .replace(/^\s*secret\s+information\s*:\s*/i, "")
    .replace(/^\s+|\s+$/g, "");
}

function formatSecretInfoDisplay(body: unknown): string {
  const cleanBody = sanitizeSecretInfoBody(body);
  return cleanBody ? `${SECRET_INFO_PREFIX} ${cleanBody}` : "";
}

function sanitizeSecretInfoDisplay(value: unknown): string {
  return formatSecretInfoDisplay(value);
}

function sanitizeStoredSecretInfo(value: unknown): string {
  return sanitizeSecretInfoDisplay(value);
}

function sanitizePriorSecretInfo(value: unknown): string {
  return sanitizeSecretInfoDisplay(value);
}

function clampHistoryEntries(value: unknown): number {
  const numeric = typeof value === "number" ? value : Number(value);
  if (!Number.isFinite(numeric)) return DEFAULT_MAX_HISTORY_ENTRIES;
  return Math.max(1, Math.floor(numeric));
}

function normalizePromptFieldsState(value: unknown): PromptFieldsState {
  const base = createDefaultPromptFieldsState();
  const incoming = (value && typeof value === "object") ? value as Partial<PromptFieldsState> : {};
  return {
    scriptSystemPrompt: typeof incoming.scriptSystemPrompt === "string" ? incoming.scriptSystemPrompt : base.scriptSystemPrompt,
    scriptPrompt: typeof incoming.scriptPrompt === "string" ? incoming.scriptPrompt : base.scriptPrompt,
    maxHistoryEntries: clampHistoryEntries(incoming.maxHistoryEntries),
    autoRefreshEachTurn: Boolean(incoming.autoRefreshEachTurn),
    useAuthorsNoteForSecretInfo: Boolean(incoming.useAuthorsNoteForSecretInfo),
    lorebookOnlyCharacterDetection: Boolean(incoming.lorebookOnlyCharacterDetection),
    secretInfoLabel: typeof incoming.secretInfoLabel === "string" && incoming.secretInfoLabel.trim()
      ? incoming.secretInfoLabel.trim()
      : base.secretInfoLabel,
  };
}

function normalizeCurrentOutputState(value: unknown): CurrentOutputState {
  const incoming = (value && typeof value === "object") ? value as Partial<CurrentOutputState> : {};
  return {
    secretInfo: sanitizeStoredSecretInfo(incoming.secretInfo),
  };
}

function normalizeHistoryLogEntry(value: unknown): HistoryLogEntry | null {
  if (!value || typeof value !== "object") return null;
  const entry = value as Partial<HistoryLogEntry>;
  const secretInfo = sanitizeSecretInfoDisplay(entry.secretInfo);
  if (!secretInfo) return null;
  return {
    sequence: typeof entry.sequence === "number" ? entry.sequence : 0,
    timestamp: typeof entry.timestamp === "string" ? entry.timestamp : new Date().toISOString(),
    nodeId: typeof entry.nodeId === "string" ? entry.nodeId : "",
    storyTurnCounter: typeof entry.storyTurnCounter === "number" ? entry.storyTurnCounter : 0,
    headerStatus: entry.headerStatus === "unchanged" ? "unchanged" : "changed",
    secretInfo,
  };
}

function normalizeGeneratedState(value: unknown): GeneratedState {
  const base = createDefaultGeneratedState();
  const incoming = (value && typeof value === "object") ? value as Partial<GeneratedState> : {};
  const rawEntries = Array.isArray(incoming.logEntries) ? incoming.logEntries : [];
  const logEntries = rawEntries
    .map((entry) => normalizeHistoryLogEntry(entry))
    .filter((entry): entry is HistoryLogEntry => entry !== null)
    .sort((a, b) => a.sequence - b.sequence);

  return {
    lastUpdatedAt: typeof incoming.lastUpdatedAt === "string" ? incoming.lastUpdatedAt : base.lastUpdatedAt,
    lastModel: typeof incoming.lastModel === "string" ? incoming.lastModel : base.lastModel,
    lastStatus: typeof incoming.lastStatus === "string" ? incoming.lastStatus : base.lastStatus,
    lastError: typeof incoming.lastError === "string" ? incoming.lastError : base.lastError,
    lastStoryTitle: typeof incoming.lastStoryTitle === "string" ? incoming.lastStoryTitle : base.lastStoryTitle,
    lastPromptDynamic: typeof incoming.lastPromptDynamic === "string" ? incoming.lastPromptDynamic : base.lastPromptDynamic,
    lastRawResponse: typeof incoming.lastRawResponse === "string" ? incoming.lastRawResponse : base.lastRawResponse,
    logEntries,
    nextLogSequence: typeof incoming.nextLogSequence === "number"
      ? Math.max(incoming.nextLogSequence, logEntries.length + 1)
      : Math.max(base.nextLogSequence, logEntries.length + 1),
    storyTurnCounter: typeof incoming.storyTurnCounter === "number" ? incoming.storyTurnCounter : base.storyTurnCounter,
    promptSeedTurnCounter: typeof incoming.promptSeedTurnCounter === "number" ? incoming.promptSeedTurnCounter : base.promptSeedTurnCounter,
    promptSeedSecretInfo: sanitizePriorSecretInfo(incoming.promptSeedSecretInfo),
    lastObservedHistoryNodeId: typeof incoming.lastObservedHistoryNodeId === "string" ? incoming.lastObservedHistoryNodeId : base.lastObservedHistoryNodeId,
  };
}

function normalizePromptPreviewState(value: unknown): PromptPreviewState {
  const incoming = (value && typeof value === "object") ? value as Partial<PromptPreviewState> : {};
  return {
    promptPreview: typeof incoming.promptPreview === "string" ? incoming.promptPreview : "",
  };
}

async function getPromptFieldsState(): Promise<PromptFieldsState> {
  return normalizePromptFieldsState(await api.v1.storyStorage.get(PROMPT_FIELDS_KEY));
}

async function setPromptFieldsState(state: PromptFieldsState): Promise<void> {
  await api.v1.storyStorage.set(PROMPT_FIELDS_KEY, normalizePromptFieldsState(state));
}

async function getCurrentOutputState(): Promise<CurrentOutputState> {
  const state = normalizeCurrentOutputState(await api.v1.storyStorage.get(CURRENT_OUTPUT_KEY));
  if (state.secretInfo !== (await api.v1.storyStorage.get(CURRENT_OUTPUT_KEY))?.secretInfo) {
    await api.v1.storyStorage.set(CURRENT_OUTPUT_KEY, state);
  }
  return state;
}

async function setCurrentOutputState(state: CurrentOutputState): Promise<void> {
  await api.v1.storyStorage.set(CURRENT_OUTPUT_KEY, normalizeCurrentOutputState(state));
}

async function getGeneratedState(): Promise<GeneratedState> {
  return normalizeGeneratedState(await api.v1.storyStorage.get(GENERATED_STATE_KEY));
}

async function setGeneratedState(state: GeneratedState): Promise<void> {
  await api.v1.storyStorage.set(GENERATED_STATE_KEY, normalizeGeneratedState(state));
}

async function getPromptPreviewState(): Promise<PromptPreviewState> {
  return normalizePromptPreviewState(await api.v1.storyStorage.get(PROMPT_PREVIEW_KEY));
}

async function setPromptPreviewState(state: PromptPreviewState): Promise<void> {
  await api.v1.storyStorage.set(PROMPT_PREVIEW_KEY, normalizePromptPreviewState(state));
}

async function getActiveEditField(): Promise<EditField> {
  const value = await api.v1.tempStorage.get(TEMP_ACTIVE_EDIT_FIELD_KEY);
  return value === "secretInfo" || value === "scriptSystemPrompt" || value === "scriptPrompt" ? value : null;
}

async function setActiveEditField(value: EditField): Promise<void> {
  if (value) {
    await api.v1.tempStorage.set(TEMP_ACTIVE_EDIT_FIELD_KEY, value);
  } else {
    await api.v1.tempStorage.remove(TEMP_ACTIVE_EDIT_FIELD_KEY);
  }
}

async function startEdit(field: Exclude<EditField, null>): Promise<void> {
  const promptFields = await getPromptFieldsState();
  const currentOutput = await getCurrentOutputState();

  await setActiveEditField(field);
  if (field === "secretInfo") {
    await api.v1.tempStorage.set(TEMP_SECRET_INFO_DRAFT_KEY, sanitizeSecretInfoBody(currentOutput.secretInfo));
  }
  if (field === "scriptSystemPrompt") {
    await api.v1.tempStorage.set(TEMP_SYSTEM_PROMPT_DRAFT_KEY, promptFields.scriptSystemPrompt);
  }
  if (field === "scriptPrompt") {
    await api.v1.tempStorage.set(TEMP_SCRIPT_PROMPT_DRAFT_KEY, promptFields.scriptPrompt);
  }
  await renderPanel();
}

async function cancelEdit(): Promise<void> {
  await setActiveEditField(null);
  await api.v1.tempStorage.remove(TEMP_SECRET_INFO_DRAFT_KEY);
  await api.v1.tempStorage.remove(TEMP_SYSTEM_PROMPT_DRAFT_KEY);
  await api.v1.tempStorage.remove(TEMP_SCRIPT_PROMPT_DRAFT_KEY);
  await renderPanel();
}

async function saveSecretInfoEdit(): Promise<void> {
  const currentOutput = await getCurrentOutputState();
  const generatedState = await getGeneratedState();
  const draft = await api.v1.tempStorage.get(TEMP_SECRET_INFO_DRAFT_KEY);
  const secretInfo = sanitizeSecretInfoDisplay(draft);

  currentOutput.secretInfo = secretInfo;
  generatedState.lastStatus = secretInfo ? "Manual secret info edit saved" : "Secret info cleared by manual edit";
  generatedState.lastError = "";

  await setCurrentOutputState(currentOutput);
  await setGeneratedState(generatedState);
  await cancelEdit();
}

async function savePromptFieldEdit(field: "scriptSystemPrompt" | "scriptPrompt"): Promise<void> {
  const promptFields = await getPromptFieldsState();
  if (field === "scriptSystemPrompt") {
    const draft = await api.v1.tempStorage.get(TEMP_SYSTEM_PROMPT_DRAFT_KEY);
    promptFields.scriptSystemPrompt = typeof draft === "string" ? draft : promptFields.scriptSystemPrompt;
  }
  if (field === "scriptPrompt") {
    const draft = await api.v1.tempStorage.get(TEMP_SCRIPT_PROMPT_DRAFT_KEY);
    promptFields.scriptPrompt = typeof draft === "string" ? draft : promptFields.scriptPrompt;
  }
  await setPromptFieldsState(promptFields);
  await rebuildPromptPreview();
  await cancelEdit();
}

async function getStoryTitle(): Promise<string> {
  try {
    const title = await api.v1.story.title.get();
    return title?.trim() || "Untitled Story";
  } catch {
    return "Untitled Story";
  }
}

async function getStoryContextText(): Promise<string> {
  const sections = await api.v1.document.scan();
  const parts = sections
    .map((item) => item.section?.text ?? "")
    .map((text) => text.trim())
    .filter(Boolean);

  const recent = parts.slice(-STORY_CONTEXT_SECTION_LIMIT).join("\n\n");
  if (recent.length <= STORY_CONTEXT_CHAR_LIMIT) return recent;
  return recent.slice(-STORY_CONTEXT_CHAR_LIMIT);
}

function buildDynamicPromptBlock(storyTitle: string, priorSecretInfo: string): string {
  const lines = [`Story title: ${storyTitle}`];
  if (priorSecretInfo) {
    lines.push(`Previous secret-info block seed: ${sanitizePriorSecretInfo(priorSecretInfo)}`);
  } else {
    lines.push("Previous secret-info block seed: [none]");
  }
  return lines.join("\n");
}

function buildPromptPreview(scriptSystemPrompt: string, lastPromptDynamic: string, scriptPrompt: string): string {
  return `SYSTEM: ${scriptSystemPrompt}\n\nUSER: ${lastPromptDynamic}\n\n${scriptPrompt}`;
}

async function rebuildPromptPreview(): Promise<void> {
  const promptFields = await getPromptFieldsState();
  const generatedState = await getGeneratedState();
  const preview = buildPromptPreview(
    promptFields.scriptSystemPrompt,
    generatedState.lastPromptDynamic,
    promptFields.scriptPrompt,
  );
  await setPromptPreviewState({ promptPreview: preview });
}

async function updateTurnSeedState(currentOutput: CurrentOutputState, generatedState: GeneratedState): Promise<GeneratedState> {
  const currentNodeId = String(await api.v1.document.history.currentNodeId());

  if (!generatedState.lastObservedHistoryNodeId) {
    generatedState.lastObservedHistoryNodeId = currentNodeId;
  }

  if (generatedState.lastObservedHistoryNodeId !== currentNodeId) {
    generatedState.lastObservedHistoryNodeId = currentNodeId;
    generatedState.storyTurnCounter += 1;

    if (currentOutput.secretInfo) {
      generatedState.promptSeedSecretInfo = sanitizePriorSecretInfo(currentOutput.secretInfo);
      generatedState.promptSeedTurnCounter = generatedState.storyTurnCounter;
    }
  }

  if (!generatedState.promptSeedSecretInfo && currentOutput.secretInfo) {
    generatedState.promptSeedSecretInfo = sanitizePriorSecretInfo(currentOutput.secretInfo);
    generatedState.promptSeedTurnCounter = generatedState.storyTurnCounter;
  }

  return generatedState;
}

function pushHistoryEntry(
  generatedState: GeneratedState,
  nodeId: string,
  storyTurnCounter: number,
  headerStatus: "changed" | "unchanged",
  secretInfo: string,
  maxHistoryEntries: number,
): GeneratedState {
  generatedState.logEntries.push({
    sequence: generatedState.nextLogSequence,
    timestamp: new Date().toISOString(),
    nodeId,
    storyTurnCounter,
    headerStatus,
    secretInfo,
  });
  generatedState.nextLogSequence += 1;
  generatedState.logEntries = generatedState.logEntries.slice(-maxHistoryEntries);
  return generatedState;
}

async function waitForGenerationBudget(messages: Message[], requestedMaxTokens: number): Promise<void> {
  const estimatedInputTokens = api.v1.script.countUncachedInputTokens(messages);
  const allowedInput = api.v1.script.getAllowedInput();
  if (allowedInput < estimatedInputTokens) {
    await api.v1.script.waitForAllowedInput(estimatedInputTokens);
  }

  const allowedOutput = api.v1.script.getAllowedOutput();
  if (allowedOutput < requestedMaxTokens) {
    await api.v1.script.waitForAllowedOutput(requestedMaxTokens);
  }
}

async function refreshSecretInfo(trigger: "manual" | "auto" = "manual"): Promise<void> {
  if (isProcessing) return;
  isProcessing = true;
  isInternalSecretInfoGeneration = true;

  const promptFields = await getPromptFieldsState();
  const currentOutput = await getCurrentOutputState();
  let generatedState = await getGeneratedState();

  try {
    generatedState.lastStatus = trigger === "auto" ? "Auto refresh running" : "Refreshing secret info";
    generatedState.lastError = "";
    await setGeneratedState(generatedState);
    await renderPanel();

    generatedState = await updateTurnSeedState(currentOutput, generatedState);

    const storyTitle = await getStoryTitle();
    const storyContext = await getStoryContextText();
    const priorSecretInfo = sanitizePriorSecretInfo(generatedState.promptSeedSecretInfo);
    const dynamicPrompt = buildDynamicPromptBlock(storyTitle, priorSecretInfo);
    const promptPreview = buildPromptPreview(
      promptFields.scriptSystemPrompt,
      dynamicPrompt,
      promptFields.scriptPrompt,
    );

    generatedState.lastStoryTitle = storyTitle;
    generatedState.lastPromptDynamic = dynamicPrompt;
    await setGeneratedState(generatedState);
    await setPromptPreviewState({ promptPreview });

    const messages: Message[] = [
      { role: "system", content: promptFields.scriptSystemPrompt },
      {
        role: "user",
        content: `${dynamicPrompt}\n\n${promptFields.scriptPrompt}\n\nSTORY CONTEXT:\n${storyContext}`,
      },
    ];

    await waitForGenerationBudget(messages, SECRET_INFO_MAX_TOKENS);

    const genParams = await api.v1.generationParameters.get();
    const response = await api.v1.generate(
      messages,
      {
        model: genParams.model,
        max_tokens: SECRET_INFO_MAX_TOKENS,
        temperature: genParams.temperature,
      },
      undefined,
      "background",
    );

    const rawText = response?.choices?.[0]?.text?.trim() || "";
    const secretInfo = sanitizeSecretInfoDisplay(rawText);
    const currentNodeId = String(await api.v1.document.history.currentNodeId());
    const headerStatus = generatedState.promptSeedTurnCounter === generatedState.storyTurnCounter
      ? "unchanged"
      : "changed";

    currentOutput.secretInfo = secretInfo;
    generatedState.lastUpdatedAt = new Date().toISOString();
    generatedState.lastModel = genParams.model;
    generatedState.lastStatus = secretInfo ? "Secret info refreshed" : "Refresh returned empty output";
    generatedState.lastError = "";
    generatedState.lastRawResponse = rawText;

    pushHistoryEntry(
      generatedState,
      currentNodeId,
      generatedState.storyTurnCounter,
      headerStatus,
      secretInfo,
      promptFields.maxHistoryEntries,
    );

    await setCurrentOutputState(currentOutput);
    await setGeneratedState(generatedState);
    await rebuildPromptPreview();
    await renderPanel();
  } catch (error) {
    const generatedState = await getGeneratedState();
    generatedState.lastStatus = "Error";
    generatedState.lastError = error instanceof Error ? error.message : String(error);
    await setGeneratedState(generatedState);
    await renderPanel();
  } finally {
    isInternalSecretInfoGeneration = false;
    isProcessing = false;
  }
}

async function clearCurrentOutput(): Promise<void> {
  const currentOutput = await getCurrentOutputState();
  const generatedState = await getGeneratedState();
  currentOutput.secretInfo = "";
  generatedState.lastStatus = "Current output cleared";
  generatedState.lastError = "";
  await setCurrentOutputState(currentOutput);
  await setGeneratedState(generatedState);
  await api.v1.tempStorage.remove(TEMP_SECRET_INFO_DRAFT_KEY);
  await renderPanel();
}

async function clearHistoryLog(): Promise<void> {
  const generatedState = await getGeneratedState();
  generatedState.logEntries = [];
  generatedState.nextLogSequence = 1;
  generatedState.lastStatus = "History log cleared";
  generatedState.lastError = "";
  await setGeneratedState(generatedState);
  await renderPanel();
}

function makeSectionHeader(text: string): UIPart {
  return {
    type: "text",
    markdown: true,
    text: `**${text}**`,
    style: {
      fontSize: "14px",
      fontWeight: "bold",
      marginTop: "12px",
      marginBottom: "6px",
    },
  };
}

async function buildCurrentOutputSection(currentOutput: CurrentOutputState): Promise<UIPart[]> {
  const activeEditField = await getActiveEditField();
  const draft = await api.v1.tempStorage.get(TEMP_SECRET_INFO_DRAFT_KEY);
  const isEditing = activeEditField === "secretInfo";

  const parts: UIPart[] = [makeSectionHeader("Current Secret Information")];

  if (isEditing) {
    parts.push(
      {
        type: "multilineTextInput",
        id: "secret-info-edit-input",
        initialValue: typeof draft === "string" ? draft : sanitizeSecretInfoBody(currentOutput.secretInfo),
        placeholder: "Secret information body text",
        label: "Secret Information Output",
        onChange: async (value: string) => {
          await api.v1.tempStorage.set(TEMP_SECRET_INFO_DRAFT_KEY, value);
        },
        style: {
          minHeight: "120px",
          marginBottom: "8px",
        },
      },
      {
        type: "row",
        spacing: "start",
        content: [
          {
            type: "button",
            text: "Save",
            callback: async () => {
              await saveSecretInfoEdit();
            },
            style: { marginRight: "8px" },
          },
          {
            type: "button",
            text: "Cancel",
            callback: async () => {
              await cancelEdit();
            },
          },
        ],
      },
    );
    return parts;
  }

  parts.push(
    {
      type: "text",
      markdown: true,
      text: currentOutput.secretInfo || "*No secret information generated yet.*",
      style: {
        whiteSpace: "pre-wrap",
        lineHeight: "1.45",
        padding: "10px",
        borderWidth: "1px",
        borderStyle: "solid",
        borderColor: "var(--borderColor)",
        borderRadius: "8px",
        backgroundColor: "var(--bg2)",
      },
    },
    {
      type: "row",
      spacing: "start",
      content: [
        {
          type: "button",
          text: "Edit",
          callback: async () => {
            await startEdit("secretInfo");
          },
          style: { marginTop: "8px", marginRight: "8px" },
        },
      ],
    },
  );

  return parts;
}

async function buildPromptFieldSection(
  title: string,
  field: "scriptSystemPrompt" | "scriptPrompt",
  value: string,
): Promise<UIPart[]> {
  const activeEditField = await getActiveEditField();
  const isEditing = activeEditField === field;
  const draftKey = field === "scriptSystemPrompt" ? TEMP_SYSTEM_PROMPT_DRAFT_KEY : TEMP_SCRIPT_PROMPT_DRAFT_KEY;
  const draft = await api.v1.tempStorage.get(draftKey);

  const parts: UIPart[] = [makeSectionHeader(title)];

  if (isEditing) {
    parts.push(
      {
        type: "multilineTextInput",
        id: `${field}-edit-input`,
        initialValue: typeof draft === "string" ? draft : value,
        label: title,
        onChange: async (nextValue: string) => {
          await api.v1.tempStorage.set(draftKey, nextValue);
        },
        style: {
          minHeight: "160px",
          marginBottom: "8px",
        },
      },
      {
        type: "row",
        spacing: "start",
        content: [
          {
            type: "button",
            text: "Save",
            callback: async () => {
              await savePromptFieldEdit(field);
            },
            style: { marginRight: "8px" },
          },
          {
            type: "button",
            text: "Cancel",
            callback: async () => {
              await cancelEdit();
            },
          },
        ],
      },
    );
    return parts;
  }

  parts.push(
    {
      type: "text",
      text: value,
      style: {
        whiteSpace: "pre-wrap",
        lineHeight: "1.4",
        padding: "10px",
        borderWidth: "1px",
        borderStyle: "solid",
        borderColor: "var(--borderColor)",
        borderRadius: "8px",
        backgroundColor: "var(--bg2)",
      },
    },
    {
      type: "button",
      text: "Edit",
      callback: async () => {
        await startEdit(field);
      },
      style: { marginTop: "8px" },
    },
  );

  return parts;
}

async function buildHistorySection(generatedState: GeneratedState): Promise<UIPart[]> {
  const parts: UIPart[] = [makeSectionHeader("Recent History Log")];
  const recent = generatedState.logEntries.slice(-RECENT_HISTORY_VISIBLE_COUNT).reverse();

  if (recent.length === 0) {
    parts.push({
      type: "text",
      markdown: true,
      text: "*No history entries yet.*",
      style: { opacity: "0.8" },
    });
    return parts;
  }

  for (let i = 0; i < recent.length; i += 1) {
    const entry = recent[i];
    const collapseKey = RECENT_HISTORY_UI_KEYS[i];
    const expanded = Boolean(await api.v1.storyStorage.get(collapseKey));
    const header = `#${entry.sequence} • turn ${entry.storyTurnCounter} • ${entry.headerStatus} • ${new Date(entry.timestamp).toLocaleString()}`;

    parts.push(
      {
        type: "checkboxInput",
        label: header,
        initialValue: expanded,
        storageKey: collapseKey,
        onChange: async (value: boolean) => {
          await api.v1.storyStorage.set(collapseKey, value);
          await renderPanel();
        },
        style: { marginTop: "4px", marginBottom: "4px" },
      },
    );

    if (expanded) {
      parts.push({
        type: "text",
        markdown: true,
        text: entry.secretInfo,
        style: {
          whiteSpace: "pre-wrap",
          lineHeight: "1.4",
          padding: "8px",
          marginBottom: "6px",
          borderWidth: "1px",
          borderStyle: "solid",
          borderColor: "var(--borderColor)",
          borderRadius: "8px",
          backgroundColor: "var(--bg2)",
        },
      });
    }
  }

  return parts;
}

function buildDiagnosticsSection(
  promptFields: PromptFieldsState,
  currentOutput: CurrentOutputState,
  generatedState: GeneratedState,
  promptPreview: PromptPreviewState,
): UIPart[] {
  const diagnosticsText = [
    `Status: ${generatedState.lastStatus || "Idle"}`,
    `Last updated: ${generatedState.lastUpdatedAt || "-"}`,
    `Model: ${generatedState.lastModel || "-"}`,
    `Story title: ${generatedState.lastStoryTitle || "-"}`,
    `Output length: ${currentOutput.secretInfo.length}`,
    `Prompt preview length: ${promptPreview.promptPreview.length}`,
    `Dynamic prompt length: ${generatedState.lastPromptDynamic.length}`,
    `History count: ${generatedState.logEntries.length}`,
    `Story turn counter: ${generatedState.storyTurnCounter}`,
    `Prompt seed turn counter: ${generatedState.promptSeedTurnCounter}`,
    `Secret label config: ${promptFields.secretInfoLabel}`,
    `Last error: ${generatedState.lastError || "-"}`,
    "",
    "Last raw response:",
    generatedState.lastRawResponse || "-",
    "",
    "Last prompt dynamic block:",
    generatedState.lastPromptDynamic || "-",
  ].join("\n");

  return [
    makeSectionHeader("Diagnostics"),
    {
      type: "text",
      text: diagnosticsText,
      style: {
        whiteSpace: "pre-wrap",
        lineHeight: "1.35",
        padding: "10px",
        borderWidth: "1px",
        borderStyle: "solid",
        borderColor: "var(--borderColor)",
        borderRadius: "8px",
        backgroundColor: "var(--bg2)",
        marginBottom: "12px",
      },
    },
  ];
}

async function buildPanelContent(): Promise<UIPart[]> {
  const promptFields = await getPromptFieldsState();
  const currentOutput = await getCurrentOutputState();
  const generatedState = await getGeneratedState();
  const promptPreview = await getPromptPreviewState();

  const parts: UIPart[] = [
    {
      type: "container",
      style: {
        padding: "12px",
        display: "flex",
        flexDirection: "column",
        gap: "0px",
      },
      content: [
        {
          type: "text",
          markdown: true,
          text: "**Secret Info Panel**",
          style: {
            fontSize: "16px",
            fontWeight: "bold",
            marginBottom: "4px",
          },
        },
        {
          type: "text",
          text: "Private continuity support for soft, uncertain, low-drama interiority.",
          style: {
            fontSize: "12px",
            opacity: "0.8",
            marginBottom: "10px",
          },
        },
        makeSectionHeader("Action Controls"),
        {
          type: "row",
          spacing: "start",
          wrap: true,
          content: [
            {
              type: "button",
              text: isProcessing ? "Refreshing..." : "Refresh",
              callback: async () => {
                await refreshSecretInfo("manual");
              },
              style: { marginRight: "8px", marginBottom: "8px" },
            },
            {
              type: "button",
              text: "Clear Output",
              callback: async () => {
                await clearCurrentOutput();
              },
              style: { marginRight: "8px", marginBottom: "8px" },
            },
            {
              type: "button",
              text: "Clear History",
              callback: async () => {
                await clearHistoryLog();
              },
              style: { marginBottom: "8px" },
            },
          ],
        },
        {
          type: "checkboxInput",
          label: "Auto refresh each turn",
          initialValue: promptFields.autoRefreshEachTurn,
          onChange: async (value: boolean) => {
            const next = await getPromptFieldsState();
            next.autoRefreshEachTurn = value;
            await setPromptFieldsState(next);
            await renderPanel();
          },
          style: { marginBottom: "8px" },
        },
        ...await buildCurrentOutputSection(currentOutput),
        ...await buildHistorySection(generatedState),
        ...await buildPromptFieldSection("Script System Prompt", "scriptSystemPrompt", promptFields.scriptSystemPrompt),
        ...await buildPromptFieldSection("Script Prompt", "scriptPrompt", promptFields.scriptPrompt),
        makeSectionHeader("Prompt Preview"),
        {
          type: "text",
          text: promptPreview.promptPreview || "Prompt preview will appear after refresh.",
          style: {
            whiteSpace: "pre-wrap",
            lineHeight: "1.4",
            padding: "10px",
            borderWidth: "1px",
            borderStyle: "solid",
            borderColor: "var(--borderColor)",
            borderRadius: "8px",
            backgroundColor: "var(--bg2)",
          },
        },
        ...buildDiagnosticsSection(promptFields, currentOutput, generatedState, promptPreview),
      ],
    },
  ];

  return parts;
}

async function renderPanel(): Promise<void> {
  const content = await buildPanelContent();

  if (!isInitialized) {
    await api.v1.ui.register([
      {
        type: "sidebarPanel",
        id: PANEL_ID,
        name: PANEL_NAME,
        iconId: PANEL_ICON,
        content,
      },
    ]);
    isInitialized = true;
    return;
  }

  await api.v1.ui.update([
    {
      type: "sidebarPanel",
      id: PANEL_ID,
      content,
    },
  ] as any);
}

const onResponse: OnResponse = (data) => {
  (async () => {
    if (!data.final) return;
    if (isInternalSecretInfoGeneration) return;
    const promptFields = await getPromptFieldsState();
    if (!promptFields.autoRefreshEachTurn) return;
    if (isProcessing) return;
    await refreshSecretInfo("auto");
  })();
  return {};
};

async function init(): Promise<void> {
  const promptFields = await getPromptFieldsState();
  const currentOutput = await getCurrentOutputState();
  const generatedState = await getGeneratedState();
  const promptPreview = await getPromptPreviewState();

  await setPromptFieldsState(promptFields);
  await setCurrentOutputState(currentOutput);
  await setGeneratedState(generatedState);
  await setPromptPreviewState(promptPreview);

  if (!promptPreview.promptPreview) {
    await rebuildPromptPreview();
  }

  api.v1.hooks.register("onResponse", onResponse);
  await renderPanel();
  api.v1.log("Secret Info Panel 1.4.21a initialized");
}

(async () => {
  try {
    await init();
  } catch (error) {
    api.v1.error("Secret Info Panel init error:", error);
  }
})();
