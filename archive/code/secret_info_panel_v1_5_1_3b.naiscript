/*---
compatibilityVersion: naiscript-1.0
id: 3a9a3c73-6c39-4a57-8d67-4f1f5b6d9f22
name: Secret Info Panel
version: "1.5.1.3b"
author: OpenAI
description: "Secret Info Panel v1.5.1.3a"
memoryLimit: 8
---*/

(() => {
  const CONFIG = {
    scriptName: 'Secret Info Panel',
    scriptVersion: '1.5.1.3b',
    model: 'glm-4-6',
    temperature: 0.55,
    maxTokens: 220,
    maxStoredChars: 2400,
    maxPromptChars: 12000,
    maxScriptLogEntries: 50,
    maxScriptLogChars: 320,
    maxScriptLogDetailChars: 500,
    maxPriorChars: 1400,
    defaultMaxHistoryEntries: 30,
    minAllowedOutputTokens: 96,
    sidebarName: 'Secret Info',
    workspacePanelHeight: '340px',
    secretEditorHeight: 210,
    promptEditorHeight: 180,
    previewEditorHeight: 220,
    historyEntryMinHeight: 110,
  };

  const STORAGE_KEYS = {
    promptFields: 'secret-info-panel-prompt-fields-v1',
    currentOutput: 'secret-info-panel-current-output-v1',
    generated: 'secret-info-panel-generated-state-v1',
    promptPreview: 'secret-info-panel-prompt-preview-v1',
    routedState: 'secret-info-panel-routed-state-v1',
  };
  const TEMP_SCRIPT_LOG_KEY = 'secret-info-panel-runtime-log-v1';
  const TEMP_EDIT_STATE_KEYS = {
    activeField: 'secret-info-panel-edit-active-field-v1',
    secretInfoDraft: 'secret-info-panel-edit-secret-info-draft-v1',
    systemPromptDraft: 'secret-info-panel-edit-system-prompt-draft-v1',
    scriptPromptDraft: 'secret-info-panel-edit-script-prompt-draft-v1',
    workspaceTab: 'secret-info-panel-workspace-tab-v1',
  };

  const DEFAULT_SECRET_INFO_LABEL = 'Secret information';
  const SECRET_INFO_PREFIX = `${DEFAULT_SECRET_INFO_LABEL}:`;

  const CANONICAL_CONTRACT_VERSION = '1.5.0.7';
  const ROUTE_LAYER_STATUS = 'not-initialized';
  const ROUTE_ADAPTER_CONTRACT_VERSION = '1.5.0.7';
  const ROUTE_FRAGMENT_KEY = 'secretInfoParagraph';
  const ROUTE_SOURCE_LAYER = 'canonicalBody';
  const ROUTE_OWNERSHIP_MODE = 'script-owned';
  const ROUTE_RECEIPT_MODE = 'placeholder';
  const ROUTE_RECEIPT_STATUS = {
    notInitialized: 'not-initialized',
    disabled: 'disabled',
    missing: 'missing',
    dirty: 'dirty',
    current: 'current',
    failed: 'failed',
  };
  const ROUTE_OWNERSHIP_STATUS = {
    unowned: 'unowned',
    reserved: 'reserved',
    confirmed: 'confirmed',
  };
  const ROUTE_PLAN_STATUS = {
    disabled: 'disabled',
    empty: 'empty',
    planned: 'planned',
    current: 'current',
    dirty: 'dirty',
  };
  const ROUTE_TARGET_NAMES = ['memory', 'authorsNote', 'lorebook'];

  const UI_IDS = {
    panel: 'sip-v2-panel',
    scriptPanel: 'sip-v2-script-panel',
    secretEditor: 'sip-v2-secret-editor',
    secretOutputViewer: 'sip-v2-secret-output-viewer',
    systemPromptEditor: 'sip-v2-system-prompt-editor',
    scriptPromptEditor: 'sip-v2-script-prompt-editor',
    logEditor: 'sip-v2-log-editor',
    refreshButton: 'sip-v2-refresh-button',
    clearButton: 'sip-v2-clear-button',
    clearLogButton: 'sip-v2-clear-log-button',
    autoRefreshToggle: 'sip-v2-auto-refresh-toggle',
    populateLogViewerButton: 'sip-v2-populate-log-viewer-button',
    clearLogViewerButton: 'sip-v2-clear-log-viewer-button',
  };

  const EDIT_FIELDS = {
    secretInfo: 'secretInfo',
    scriptSystemPrompt: 'scriptSystemPrompt',
    scriptPrompt: 'scriptPrompt',
  };
  const EDIT_DRAFT_PERSIST_DEBOUNCE_MS = 220;

  const runtime = {
    busy: false,
    storyGenerationActive: false,
    fullLogViewerText: '',
    scriptLogEntries: [],
    completedContinuityIds: new Set(),
    deferScriptLogPersistence: false,
    nextRefreshToken: 1,
    activeRefresh: null,
    editSession: {
      activeField: '',
      draftValue: '',
      persistTimerId: null,
      persistToken: 0,
    },
    workspaceTab: 'secretInfo',
  };

  function createDefaultPromptFieldState() {
    return {
      scriptSystemPrompt: getDefaultSystemPrompt(),
      scriptPrompt: getDefaultScriptPrompt(),
      maxHistoryEntries: CONFIG.defaultMaxHistoryEntries,
      autoRefreshEachTurn: false,
      useAuthorsNoteForSecretInfo: false,
      lorebookOnlyCharacterDetection: false,
      secretInfoLabel: DEFAULT_SECRET_INFO_LABEL,
    };
  }

  function createDefaultCurrentOutputState() {
    return {
      secretInfo: '',
      canonicalBody: '',
      derivedDisplayText: '',
    };
  }

  function createDefaultGeneratedState() {
    return {
      lastUpdatedAt: '',
      lastModel: CONFIG.model,
      lastStatus: 'Idle. Press Refresh to generate a secret-info block from the current story context.',
      lastError: '',
      lastStoryTitle: '',
      lastPromptDynamic: '',
      lastRawResponse: '',
      lastRawResponseBody: '',
      canonicalContractVersion: CANONICAL_CONTRACT_VERSION,
      routedFragmentStatus: ROUTE_LAYER_STATUS,
      routingReceiptStatus: ROUTE_LAYER_STATUS,
      storyTurnCounter: 0,
      promptSeedTurnCounter: -1,
      promptSeedSecretInfo: '',
      logEntries: [],
      nextLogSequence: 1,
      autoRefreshActive: false,
      autoRefreshStartedAt: '',
      autoRefreshContinuityId: '',
      autoRefreshSource: '',
    };
  }


  function getRouteTargetLabel(targetName) {
    switch (targetName) {
      case 'memory':
        return 'Memory';
      case 'authorsNote':
        return 'Author\'s Note';
      case 'lorebook':
        return 'Lorebook';
      default:
        return cleanInline(targetName || '') || 'Unknown';
    }
  }

  function createRouteAdapterDefinition(targetName) {
    const cleanTargetName = cleanInline(targetName || '');
    return {
      targetName: cleanTargetName,
      targetLabel: getRouteTargetLabel(cleanTargetName),
      adapterKey: `secret-info-${cleanTargetName}`,
      adapterVersion: ROUTE_ADAPTER_CONTRACT_VERSION,
      sourceLayer: ROUTE_SOURCE_LAYER,
      fragmentKey: ROUTE_FRAGMENT_KEY,
      ownershipMode: ROUTE_OWNERSHIP_MODE,
      receiptMode: ROUTE_RECEIPT_MODE,
    };
  }

  function createRouteAdapterRegistry() {
    const registry = {};

    for (const name of ROUTE_TARGET_NAMES) {
      registry[name] = createRouteAdapterDefinition(name);
    }

    return registry;
  }

  function createRouteOwnershipMarker(targetName) {
    const adapter = createRouteAdapterDefinition(targetName);
    return `sip-ownership:${adapter.adapterKey}`;
  }

  function deriveRouteOwnershipStatus(targetState) {
    if (!targetState.enabled) return ROUTE_OWNERSHIP_STATUS.unowned;
    if (targetState.ownedBlockId && targetState.ownershipMarker) return ROUTE_OWNERSHIP_STATUS.confirmed;
    return ROUTE_OWNERSHIP_STATUS.reserved;
  }

  function deriveRouteReceiptStatus(targetState) {
    if (!targetState.enabled) return ROUTE_RECEIPT_STATUS.disabled;
    if (cleanParagraph(targetState.lastReceiptError || '')) return ROUTE_RECEIPT_STATUS.failed;
    if (!cleanInline(targetState.desiredSignature || '')) return ROUTE_LAYER_STATUS;
    if (!cleanInline(targetState.lastAppliedSignature || '')) return ROUTE_RECEIPT_STATUS.missing;
    if (cleanInline(targetState.lastAppliedSignature || '') !== cleanInline(targetState.desiredSignature || '')) {
      return ROUTE_RECEIPT_STATUS.dirty;
    }
    return ROUTE_RECEIPT_STATUS.current;
  }

  function deriveRoutingReceiptStatusFromTargets(targets) {
    const list = ROUTE_TARGET_NAMES.map((name) => targets[name]).filter(Boolean);
    if (!list.length) return ROUTE_LAYER_STATUS;

    const enabledTargets = list.filter((target) => target.enabled);
    if (!enabledTargets.length) return ROUTE_RECEIPT_STATUS.disabled;
    if (enabledTargets.some((target) => target.receiptStatus === ROUTE_RECEIPT_STATUS.failed)) return ROUTE_RECEIPT_STATUS.failed;
    if (enabledTargets.some((target) => target.receiptStatus === ROUTE_RECEIPT_STATUS.dirty)) return ROUTE_RECEIPT_STATUS.dirty;
    if (enabledTargets.some((target) => target.receiptStatus === ROUTE_RECEIPT_STATUS.missing)) return ROUTE_RECEIPT_STATUS.missing;
    if (enabledTargets.every((target) => target.receiptStatus === ROUTE_RECEIPT_STATUS.current)) return ROUTE_RECEIPT_STATUS.current;
    return ROUTE_LAYER_STATUS;
  }

  function deriveRoutedFragmentStatus(canonicalBody) {
    return canonicalBody ? 'ready' : ROUTE_LAYER_STATUS;
  }

  function createDefaultRoutedTargetState(targetName = '') {
    const adapter = createRouteAdapterDefinition(targetName);
    return {
      enabled: false,
      status: ROUTE_LAYER_STATUS,
      adapterKey: adapter.adapterKey,
      adapterVersion: adapter.adapterVersion,
      targetName: adapter.targetName,
      targetLabel: adapter.targetLabel,
      sourceLayer: adapter.sourceLayer,
      fragmentKey: adapter.fragmentKey,
      ownershipMode: adapter.ownershipMode,
      receiptMode: adapter.receiptMode,
      ownershipMarker: createRouteOwnershipMarker(targetName),
      ownershipStatus: ROUTE_OWNERSHIP_STATUS.unowned,
      ownedBlockId: '',
      desiredSignature: '',
      lastAppliedAt: '',
      lastAppliedSignature: '',
      receiptStatus: ROUTE_LAYER_STATUS,
      receiptUpdatedAt: '',
      lastReceiptError: '',
      plannedFragment: '',
      plannedSignature: '',
      planStatus: ROUTE_PLAN_STATUS.empty,
      planUpdatedAt: '',
    };
  }

  function createDefaultRoutedState() {
    return {
      contractVersion: CANONICAL_CONTRACT_VERSION,
      adapterContractVersion: ROUTE_ADAPTER_CONTRACT_VERSION,
      sourceCanonicalSignature: '',
      sourceCanonicalUpdatedAt: '',
      routedFragmentStatus: ROUTE_LAYER_STATUS,
      routingReceiptStatus: ROUTE_LAYER_STATUS,
      lastReceiptSweepAt: '',
      targets: {
        memory: createDefaultRoutedTargetState('memory'),
        authorsNote: createDefaultRoutedTargetState('authorsNote'),
        lorebook: createDefaultRoutedTargetState('lorebook'),
      },
    };
  }

  function createDefaultPromptPreviewState() {
    return {
      promptPreview: buildPromptPreviewFromParts({
        scriptSystemPrompt: getDefaultSystemPrompt(),
        promptDynamic: '',
        scriptPrompt: getDefaultScriptPrompt(),
      }),
    };
  }

  function createDefaultState() {
    return {
      ...createDefaultPromptFieldState(),
      ...createDefaultCurrentOutputState(),
      ...createDefaultGeneratedState(),
      ...createDefaultPromptPreviewState(),
      routedState: createDefaultRoutedState(),
    };
  }

  function cleanInline(value) {
    return String(value || '')
      .replace(/\r/g, '')
      .replace(/[ \t]+\n/g, '\n')
      .replace(/\n[ \t]+/g, '\n')
      .replace(/[ \t]{2,}/g, ' ')
      .trim();
  }

  function cleanParagraph(value) {
    return cleanInline(value)
      .replace(/\n{3,}/g, '\n\n')
      .trim();
  }

  function stripCodeFence(value) {
    return String(value || '')
      .replace(/^```[a-z0-9_-]*\s*/i, '')
      .replace(/\s*```$/i, '')
      .trim();
  }

  function clipText(value, maxChars) {
    const text = String(value || '').trim();
    if (!text) return '';
    if (!Number.isFinite(maxChars) || maxChars < 1 || text.length <= maxChars) return text;
    return text.slice(0, Math.max(0, maxChars - 1)).trimEnd() + '...';
  }

  function formatTimestamp(date = new Date()) {
    try {
      return date.toLocaleString();
    } catch (_err) {
      return new Date().toISOString();
    }
  }

  function sanitizeHistoryLimit(value) {
    const num = Number(value);
    if (!Number.isFinite(num)) return CONFIG.defaultMaxHistoryEntries;
    return Math.max(1, Math.floor(num));
  }

  function sanitizeTurnCounter(value) {
    const num = Number(value);
    if (!Number.isFinite(num)) return 0;
    return Math.max(0, Math.floor(num));
  }

  function sanitizePromptSeedTurnCounter(value) {
    const num = Number(value);
    if (!Number.isFinite(num)) return -1;
    return Math.max(-1, Math.floor(num));
  }

  function sanitizeAutoRefreshSource(value) {
    const source = cleanInline(value || '');
    return ['manual', 'auto'].includes(source) ? source : 'auto';
  }

  function sanitizeContinuityId(value) {
    return cleanInline(value || '');
  }

  function sanitizeSecretInfoBody(value) {
    let text = cleanParagraph(stripCodeFence(value || ''));
    text = text.replace(/^\s*secret\s+information\s*/i, `${DEFAULT_SECRET_INFO_LABEL}`);

    for (let i = 0; i < 4; i += 1) {
      const next = text
        .replace(/^\s*secret\s+information\s*:\s*/i, '')
        .replace(/^\s*secret\s+information\s+/i, '')
        .trim();

      if (next === text) break;
      text = next;
    }

    return text
      .replace(/\s+/g, ' ')
      .trim();
  }

  function formatSecretInfoDisplay(value) {
    const body = sanitizeSecretInfoBody(value);
    if (!body) return '';
    return `${SECRET_INFO_PREFIX} ${body}`;
  }

  function sanitizePriorSecretInfo(value) {
    return clipText(formatSecretInfoDisplay(value), CONFIG.maxPriorChars);
  }

  function sanitizeStoredSecretInfo(value) {
    return clipText(formatSecretInfoDisplay(value), CONFIG.maxStoredChars);
  }

  function sanitizeRawDiagnosticResponse(value) {
    return clipText(cleanParagraph(stripCodeFence(value || '')), CONFIG.maxStoredChars);
  }

  function preserveRawDiagnosticResponse(value) {
    return clipText(String(value == null ? '' : value), CONFIG.maxStoredChars);
  }

  function createCanonicalSignature(value) {
    const text = sanitizeSecretInfoBody(value || '');
    if (!text) return '';
    let checksum = 0;
    for (let i = 0; i < text.length; i += 1) {
      checksum = (checksum + (text.charCodeAt(i) * (i + 1))) % 1000000007;
    }
    return `${text.length}:${checksum}`;
  }

  function sanitizeRoutedTargets(value) {
    const source = value && typeof value === 'object' ? value : {};
    const targets = {};

    for (const name of ROUTE_TARGET_NAMES) {
      const target = source[name] && typeof source[name] === 'object' ? source[name] : {};
      const adapter = createDefaultRoutedTargetState(name);
      const nextTarget = {
        ...adapter,
        enabled: Boolean(target.enabled),
        status: cleanInline(target.status || '') || ROUTE_LAYER_STATUS,
        ownershipMarker: cleanInline(target.ownershipMarker || '') || adapter.ownershipMarker,
        ownershipStatus: cleanInline(target.ownershipStatus || '') || adapter.ownershipStatus,
        ownedBlockId: cleanInline(target.ownedBlockId || ''),
        desiredSignature: cleanInline(target.desiredSignature || ''),
        lastAppliedAt: cleanInline(target.lastAppliedAt || ''),
        lastAppliedSignature: cleanInline(target.lastAppliedSignature || ''),
        receiptStatus: cleanInline(target.receiptStatus || '') || ROUTE_LAYER_STATUS,
        receiptUpdatedAt: cleanInline(target.receiptUpdatedAt || ''),
        lastReceiptError: cleanParagraph(target.lastReceiptError || ''),
        plannedFragment: sanitizeSecretInfoBody(target.plannedFragment || ''),
        plannedSignature: cleanInline(target.plannedSignature || ''),
        planStatus: cleanInline(target.planStatus || '') || ROUTE_PLAN_STATUS.empty,
        planUpdatedAt: cleanInline(target.planUpdatedAt || ''),
      };

      nextTarget.ownershipStatus = deriveRouteOwnershipStatus(nextTarget);
      nextTarget.receiptStatus = deriveRouteReceiptStatus(nextTarget);
      targets[name] = nextTarget;
    }

    return targets;
  }

  function deriveRawResponseLayers(sourceState = {}) {
    const rawResponseText = sanitizeRawDiagnosticResponse(sourceState.lastRawResponse || '');
    const rawResponseBody = sanitizeSecretInfoBody(sourceState.lastRawResponseBody || rawResponseText);

    return {
      rawResponseText,
      rawResponseBody,
    };
  }

  function deriveCanonicalLayers(sourceState = {}) {
    const canonicalBody = sanitizeSecretInfoBody(sourceState.canonicalBody || sourceState.secretInfo || '');
    const derivedDisplayText = formatSecretInfoDisplay(canonicalBody);

    return {
      canonicalBody,
      derivedDisplayText,
      routedFragments: {
        secretInfoParagraph: canonicalBody,
      },
      routingReceipt: {
        contractVersion: CANONICAL_CONTRACT_VERSION,
        routedFragmentStatus: ROUTE_LAYER_STATUS,
        routingReceiptStatus: ROUTE_LAYER_STATUS,
        targetCount: ROUTE_TARGET_NAMES.length,
        canonicalSignature: createCanonicalSignature(canonicalBody),
      },
    };
  }

  function commitCanonicalOutput(sourceState = {}, canonicalBodyInput = '') {
    const canonicalBody = sanitizeSecretInfoBody(canonicalBodyInput);
    const derivedDisplayText = formatSecretInfoDisplay(canonicalBody);

    return {
      ...sourceState,
      secretInfo: derivedDisplayText,
      canonicalBody,
      derivedDisplayText,
    };
  }

  function commitRawDiagnosticOutput(sourceState = {}, rawResponseTextInput = '', rawResponseBodyInput = '') {
    const lastRawResponse = sanitizeRawDiagnosticResponse(rawResponseTextInput);
    const lastRawResponseBody = sanitizeSecretInfoBody(
      rawResponseBodyInput || rawResponseTextInput
    );

    return {
      ...sourceState,
      lastRawResponse,
      lastRawResponseBody,
    };
  }

  function deriveRoutePlanStatus(targetState) {
    if (!targetState.enabled) return ROUTE_PLAN_STATUS.disabled;
    if (!cleanInline(targetState.desiredSignature || '')) return ROUTE_PLAN_STATUS.empty;
    if (!cleanInline(targetState.lastAppliedSignature || '')) return ROUTE_PLAN_STATUS.planned;
    if (cleanInline(targetState.lastAppliedSignature || '') === cleanInline(targetState.desiredSignature || '')) {
      return ROUTE_PLAN_STATUS.current;
    }
    return ROUTE_PLAN_STATUS.dirty;
  }

  function createRoutePreviewFragment(targetName, canonicalBody) {
    return sanitizeSecretInfoBody(canonicalBody || '');
  }

  function applyRoutePreviewPlan(targetState, targetName, canonicalBody, updatedAt = '') {
    const plannedFragment = createRoutePreviewFragment(targetName, canonicalBody);
    const plannedSignature = createCanonicalSignature(plannedFragment);
    const nextTarget = {
      ...targetState,
      desiredSignature: plannedSignature,
      plannedFragment,
      plannedSignature,
      planUpdatedAt: cleanInline(updatedAt || targetState.planUpdatedAt || ''),
    };

    nextTarget.planStatus = deriveRoutePlanStatus(nextTarget);
    return nextTarget;
  }

  function getCompactRouteTargetLabel(targetName) {
    switch (targetName) {
      case 'memory':
        return 'Memory';
      case 'authorsNote':
        return 'A/N';
      case 'lorebook':
        return 'Lorebook';
      default:
        return cleanInline(targetName || '') || 'Unknown';
    }
  }

  function getCompactRoutePlanStatus(planStatus) {
    switch (cleanInline(planStatus || '')) {
      case ROUTE_PLAN_STATUS.disabled:
        return 'Off';
      case ROUTE_PLAN_STATUS.empty:
        return 'On';
      case ROUTE_PLAN_STATUS.planned:
        return 'Planned';
      case ROUTE_PLAN_STATUS.current:
        return 'Current';
      case ROUTE_PLAN_STATUS.dirty:
        return 'Dirty';
      default:
        return 'Unknown';
    }
  }

  function buildRoutePlannerSummary(routedState) {
    const source = routedState && typeof routedState === 'object' ? routedState : createDefaultRoutedState();
    const targets = sanitizeRoutedTargets(source.targets);
    return ROUTE_TARGET_NAMES.map((name) => {
      const target = targets[name];
      return `${getCompactRouteTargetLabel(name)} ${getCompactRoutePlanStatus(target.planStatus)}`;
    }).join(' | ');
  }

  function sanitizeLogEntries(entries, maxEntries = CONFIG.defaultMaxHistoryEntries) {
    if (!Array.isArray(entries)) return [];

    const cleaned = entries
      .filter((entry) => entry && typeof entry === 'object')
      .map((entry) => ({
        sequence: Number.isFinite(entry.sequence) ? Math.max(0, Math.floor(entry.sequence)) : 0,
        updatedAt: cleanInline(entry.updatedAt || ''),
        storyTitle: cleanInline(entry.storyTitle || ''),
        source: cleanInline(entry.source || 'manual'),
        turnCounter: sanitizeTurnCounter(entry.turnCounter),
        changedFromPrevious: Boolean(entry.changedFromPrevious),
        secretInfo: clipText(cleanParagraph(entry.secretInfo || ''), CONFIG.maxStoredChars),
      }))
      .filter((entry) => entry.secretInfo)
      .sort((a, b) => {
        const aSeq = Number.isFinite(a.sequence) ? a.sequence : 0;
        const bSeq = Number.isFinite(b.sequence) ? b.sequence : 0;
        return aSeq - bSeq;
      });

    const safeMaxEntries = sanitizeHistoryLimit(maxEntries);
    if (cleaned.length <= safeMaxEntries) return cleaned;
    return cleaned.slice(-safeMaxEntries);
  }


  function sanitizeScriptLogEntries(entries) {
    if (!Array.isArray(entries)) return [];
    return entries
      .filter((entry) => entry && typeof entry === 'object')
      .map((entry) => ({
        timestamp: cleanInline(entry.timestamp || formatTimestamp()),
        level: ['info', 'warn', 'error'].includes(entry.level) ? entry.level : 'info',
        message: clipText(cleanInline(entry.message || ''), CONFIG.maxScriptLogChars),
        details: clipText(cleanParagraph(entry.details || ''), CONFIG.maxScriptLogDetailChars),
      }))
      .filter((entry) => entry.message)
      .slice(-CONFIG.maxScriptLogEntries);
  }

  async function loadScriptLogEntries() {
    const raw = await api.v1.tempStorage.get(TEMP_SCRIPT_LOG_KEY);
    const entries = sanitizeScriptLogEntries(raw);
    runtime.scriptLogEntries = entries;
    return entries;
  }

  async function saveScriptLogEntries(entries) {
    const safeEntries = sanitizeScriptLogEntries(entries);
    runtime.scriptLogEntries = safeEntries;
    await api.v1.tempStorage.set(TEMP_SCRIPT_LOG_KEY, safeEntries);
    return safeEntries;
  }

  async function flushScriptLogEntries() {
    try {
      return await saveScriptLogEntries(runtime.scriptLogEntries || []);
    } catch (_err) {
      return runtime.scriptLogEntries || [];
    }
  }

  async function pushScriptLog(level, message, details = '') {
    const safeLevel = ['info', 'warn', 'error'].includes(level) ? level : 'info';
    const entry = {
      timestamp: formatTimestamp(),
      level: safeLevel,
      message: clipText(cleanInline(message || ''), CONFIG.maxScriptLogChars),
      details: clipText(cleanParagraph(details || ''), CONFIG.maxScriptLogDetailChars),
    };

    try {
      const current = runtime.scriptLogEntries.length ? runtime.scriptLogEntries : await loadScriptLogEntries();
      const next = sanitizeScriptLogEntries([...(current || []), entry]);
      runtime.scriptLogEntries = next;
      if (!runtime.deferScriptLogPersistence) {
        await saveScriptLogEntries(next);
      }
    } catch (err) {
      runtime.scriptLogEntries = sanitizeScriptLogEntries([...(runtime.scriptLogEntries || []), entry]);
    }

    const consoleParts = [`[${CONFIG.scriptName}]`, entry.message];
    if (entry.details) consoleParts.push(entry.details);

    try {
      if (safeLevel === 'error' && typeof api.v1.error === 'function') {
        api.v1.error(...consoleParts);
      } else {
        api.v1.log(...consoleParts);
      }
    } catch (_) {
    }

    return entry;
  }


  // -----------------------------
  // State Store Module
  // -----------------------------
  async function loadState() {
    const [rawPromptFields, rawCurrentOutput, rawGenerated, rawPromptPreview, rawRoutedState] = await Promise.all([
      api.v1.storyStorage.get(STORAGE_KEYS.promptFields),
      api.v1.storyStorage.get(STORAGE_KEYS.currentOutput),
      api.v1.storyStorage.get(STORAGE_KEYS.generated),
      api.v1.storyStorage.get(STORAGE_KEYS.promptPreview),
      api.v1.storyStorage.get(STORAGE_KEYS.routedState),
    ]);

    const promptFields = {
      ...createDefaultPromptFieldState(),
      ...(rawPromptFields && typeof rawPromptFields === 'object' ? rawPromptFields : {}),
    };
    promptFields.maxHistoryEntries = sanitizeHistoryLimit(promptFields.maxHistoryEntries);

    const currentOutput = {
      ...createDefaultCurrentOutputState(),
      ...(rawCurrentOutput && typeof rawCurrentOutput === 'object' ? rawCurrentOutput : {}),
    };

    const generated = {
      ...createDefaultGeneratedState(),
      ...(rawGenerated && typeof rawGenerated === 'object' ? rawGenerated : {}),
    };

    const logEntries = sanitizeLogEntries(generated.logEntries, promptFields.maxHistoryEntries);
    const lastSequence = logEntries.length ? Math.max(0, Math.floor(logEntries[logEntries.length - 1].sequence || 0)) : 0;
    const nextLogSequence = Number.isFinite(generated.nextLogSequence)
      ? Math.max(lastSequence + 1, Math.floor(generated.nextLogSequence))
      : (lastSequence + 1);

    generated.storyTurnCounter = sanitizeTurnCounter(generated.storyTurnCounter);
    generated.promptSeedTurnCounter = sanitizePromptSeedTurnCounter(generated.promptSeedTurnCounter);
    generated.promptSeedSecretInfo = sanitizePriorSecretInfo(generated.promptSeedSecretInfo || '');
    generated.autoRefreshActive = Boolean(generated.autoRefreshActive);
    generated.autoRefreshStartedAt = cleanInline(generated.autoRefreshStartedAt || '');
    generated.autoRefreshContinuityId = sanitizeContinuityId(generated.autoRefreshContinuityId || '');
    generated.autoRefreshSource = sanitizeAutoRefreshSource(generated.autoRefreshSource || 'auto');

    const routedState = {
      ...createDefaultRoutedState(),
      ...(rawRoutedState && typeof rawRoutedState === 'object' ? rawRoutedState : {}),
    };
    routedState.contractVersion = CANONICAL_CONTRACT_VERSION;
    routedState.adapterContractVersion = ROUTE_ADAPTER_CONTRACT_VERSION;
    routedState.routedFragmentStatus = cleanInline(routedState.routedFragmentStatus || '') || ROUTE_LAYER_STATUS;
    routedState.routingReceiptStatus = cleanInline(routedState.routingReceiptStatus || '') || ROUTE_LAYER_STATUS;
    routedState.sourceCanonicalSignature = cleanInline(routedState.sourceCanonicalSignature || '');
    routedState.sourceCanonicalUpdatedAt = cleanInline(routedState.sourceCanonicalUpdatedAt || '');
    routedState.lastReceiptSweepAt = cleanInline(routedState.lastReceiptSweepAt || '');
    routedState.targets = sanitizeRoutedTargets(routedState.targets);

    const canonicalCommittedOutput = commitCanonicalOutput(
      {},
      currentOutput.canonicalBody || currentOutput.secretInfo || ''
    );
    const canonicalLayers = deriveCanonicalLayers({
      canonicalBody: canonicalCommittedOutput.canonicalBody,
    });
    const rawResponseLayers = deriveRawResponseLayers({
      lastRawResponse: generated.lastRawResponse || '',
      lastRawResponseBody: generated.lastRawResponseBody || '',
    });
    const secretInfo = canonicalCommittedOutput.secretInfo;
    routedState.sourceCanonicalSignature = createCanonicalSignature(canonicalLayers.canonicalBody);
    routedState.routedFragmentStatus = deriveRoutedFragmentStatus(canonicalLayers.canonicalBody);
    for (const name of ROUTE_TARGET_NAMES) {
      const target = applyRoutePreviewPlan(
        routedState.targets[name],
        name,
        canonicalLayers.canonicalBody,
        routedState.sourceCanonicalUpdatedAt || generated.lastUpdatedAt || ''
      );
      target.ownershipStatus = deriveRouteOwnershipStatus(target);
      target.receiptStatus = deriveRouteReceiptStatus(target);
      routedState.targets[name] = target;
    }
    routedState.routingReceiptStatus = deriveRoutingReceiptStatusFromTargets(routedState.targets);
    const storyTitle = cleanInline(generated.lastStoryTitle || '');
    const priorSecretInfo = getPromptSeedSecretInfo({
      ...promptFields,
      ...currentOutput,
      ...generated,
      secretInfo,
    });
    const promptArtifacts = derivePromptArtifacts({
      scriptSystemPrompt: promptFields.scriptSystemPrompt,
      scriptPrompt: promptFields.scriptPrompt,
      storyTitle,
      priorSecretInfo,
    });

    const promptPreviewState = {
      ...createDefaultPromptPreviewState(),
      ...(rawPromptPreview && typeof rawPromptPreview === 'object' ? rawPromptPreview : {}),
    };

    return {
      ...createDefaultState(),
      ...promptFields,
      ...currentOutput,
      ...generated,
      secretInfo,
      canonicalBody: canonicalLayers.canonicalBody,
      derivedDisplayText: canonicalLayers.derivedDisplayText,
      lastRawResponse: rawResponseLayers.rawResponseText,
      lastRawResponseBody: rawResponseLayers.rawResponseBody,
      canonicalContractVersion: CANONICAL_CONTRACT_VERSION,
      routedFragmentStatus: routedState.routedFragmentStatus,
      routingReceiptStatus: routedState.routingReceiptStatus,
      adapterContractVersion: routedState.adapterContractVersion,
      lastReceiptSweepAt: routedState.lastReceiptSweepAt,
      routedState,
      logEntries,
      nextLogSequence,
      lastPromptDynamic: promptArtifacts.promptDynamic,
      promptPreview: cleanParagraph(promptPreviewState.promptPreview || '') || promptArtifacts.promptPreview,
    };
  }

  async function saveState(state) {
    const sourceState = state || {};
    const canonicalCommittedState = commitCanonicalOutput(
      sourceState,
      sourceState.canonicalBody || sourceState.secretInfo || ''
    );
    const rawDiagnosticCommittedState = commitRawDiagnosticOutput(
      sourceState,
      sourceState.lastRawResponse || '',
      sourceState.lastRawResponseBody || ''
    );
    const canonicalLayers = deriveCanonicalLayers({
      canonicalBody: canonicalCommittedState.canonicalBody,
    });
    const rawResponseLayers = deriveRawResponseLayers(rawDiagnosticCommittedState);
    const promptFields = {
      ...createDefaultPromptFieldState(),
      scriptSystemPrompt: cleanParagraph(sourceState.scriptSystemPrompt || '') || getDefaultSystemPrompt(),
      scriptPrompt: cleanParagraph(sourceState.scriptPrompt || '') || getDefaultScriptPrompt(),
      maxHistoryEntries: sanitizeHistoryLimit(sourceState.maxHistoryEntries),
      autoRefreshEachTurn: Boolean(sourceState.autoRefreshEachTurn),
      useAuthorsNoteForSecretInfo: Boolean(sourceState.useAuthorsNoteForSecretInfo),
      lorebookOnlyCharacterDetection: Boolean(sourceState.lorebookOnlyCharacterDetection),
      secretInfoLabel: cleanInline(sourceState.secretInfoLabel || '') || DEFAULT_SECRET_INFO_LABEL,
    };

    const currentOutput = {
      ...createDefaultCurrentOutputState(),
      secretInfo: canonicalCommittedState.secretInfo,
      canonicalBody: canonicalCommittedState.canonicalBody,
      derivedDisplayText: canonicalCommittedState.derivedDisplayText,
    };

    const generatedSource = {
      ...createDefaultGeneratedState(),
      lastUpdatedAt: cleanInline(sourceState.lastUpdatedAt || ''),
      lastModel: cleanInline(sourceState.lastModel || CONFIG.model) || CONFIG.model,
      lastStatus: cleanParagraph(sourceState.lastStatus || '') || createDefaultGeneratedState().lastStatus,
      lastError: cleanParagraph(sourceState.lastError || ''),
      lastStoryTitle: cleanInline(sourceState.lastStoryTitle || ''),
      lastRawResponse: rawResponseLayers.rawResponseText,
      lastRawResponseBody: rawResponseLayers.rawResponseBody,
      canonicalContractVersion: CANONICAL_CONTRACT_VERSION,
      routedFragmentStatus: cleanInline(sourceState.routedFragmentStatus || '') || ROUTE_LAYER_STATUS,
      routingReceiptStatus: cleanInline(sourceState.routingReceiptStatus || '') || ROUTE_LAYER_STATUS,
      storyTurnCounter: sanitizeTurnCounter(sourceState.storyTurnCounter),
      promptSeedTurnCounter: sanitizePromptSeedTurnCounter(sourceState.promptSeedTurnCounter),
      promptSeedSecretInfo: sanitizePriorSecretInfo(sourceState.promptSeedSecretInfo || ''),
      logEntries: sanitizeLogEntries(sourceState.logEntries, promptFields.maxHistoryEntries),
      nextLogSequence: Number.isFinite(sourceState.nextLogSequence) ? Math.max(1, Math.floor(sourceState.nextLogSequence)) : 1,
      autoRefreshActive: Boolean(sourceState.autoRefreshActive),
      autoRefreshStartedAt: cleanInline(sourceState.autoRefreshStartedAt || ''),
      autoRefreshContinuityId: sanitizeContinuityId(sourceState.autoRefreshContinuityId || ''),
      autoRefreshSource: sanitizeAutoRefreshSource(sourceState.autoRefreshSource || 'auto'),
    };

    const lastSequence = generatedSource.logEntries.length
      ? Math.max(0, Math.floor(generatedSource.logEntries[generatedSource.logEntries.length - 1].sequence || 0))
      : 0;

    const routedSource = {
      ...createDefaultRoutedState(),
      ...(sourceState.routedState && typeof sourceState.routedState === 'object' ? sourceState.routedState : {}),
      contractVersion: CANONICAL_CONTRACT_VERSION,
      adapterContractVersion: ROUTE_ADAPTER_CONTRACT_VERSION,
      sourceCanonicalSignature: createCanonicalSignature(canonicalLayers.canonicalBody),
      sourceCanonicalUpdatedAt: cleanInline(sourceState.lastUpdatedAt || ''),
      routedFragmentStatus: deriveRoutedFragmentStatus(canonicalLayers.canonicalBody),
      routingReceiptStatus: cleanInline(sourceState.routingReceiptStatus || '') || ROUTE_LAYER_STATUS,
      lastReceiptSweepAt: cleanInline(sourceState.lastUpdatedAt || ''),
      targets: sanitizeRoutedTargets(sourceState.routedState?.targets),
    };

    for (const name of ROUTE_TARGET_NAMES) {
      const target = applyRoutePreviewPlan(
        routedSource.targets[name],
        name,
        canonicalLayers.canonicalBody,
        routedSource.sourceCanonicalUpdatedAt || cleanInline(sourceState.lastUpdatedAt || '')
      );
      target.ownershipStatus = deriveRouteOwnershipStatus(target);
      target.receiptStatus = deriveRouteReceiptStatus(target);
      if (!target.receiptUpdatedAt) {
        target.receiptUpdatedAt = cleanInline(sourceState.lastUpdatedAt || '');
      }
      routedSource.targets[name] = target;
    }

    routedSource.routingReceiptStatus = deriveRoutingReceiptStatusFromTargets(routedSource.targets);

    const priorSecretInfo = getPromptSeedSecretInfo({
      ...promptFields,
      ...currentOutput,
      ...generatedSource,
    });
    const promptArtifacts = derivePromptArtifacts({
      scriptSystemPrompt: promptFields.scriptSystemPrompt,
      scriptPrompt: promptFields.scriptPrompt,
      storyTitle: generatedSource.lastStoryTitle,
      priorSecretInfo,
    });

    const generated = {
      ...generatedSource,
      lastPromptDynamic: promptArtifacts.promptDynamic,
      nextLogSequence: Math.max(lastSequence + 1, generatedSource.nextLogSequence),
    };

    await Promise.all([
      api.v1.storyStorage.set(STORAGE_KEYS.promptFields, promptFields),
      api.v1.storyStorage.set(STORAGE_KEYS.currentOutput, currentOutput),
      api.v1.storyStorage.set(STORAGE_KEYS.generated, generated),
      api.v1.storyStorage.set(STORAGE_KEYS.promptPreview, { promptPreview: promptArtifacts.promptPreview }),
      api.v1.storyStorage.set(STORAGE_KEYS.routedState, routedSource),
    ]);

    return {
      ...createDefaultState(),
      ...promptFields,
      ...currentOutput,
      ...generated,
      secretInfo: currentOutput.secretInfo,
      canonicalBody: currentOutput.canonicalBody,
      derivedDisplayText: currentOutput.derivedDisplayText,
      lastRawResponseBody: generated.lastRawResponseBody,
      adapterContractVersion: routedSource.adapterContractVersion,
      routedFragmentStatus: routedSource.routedFragmentStatus,
      routingReceiptStatus: routedSource.routingReceiptStatus,
      lastReceiptSweepAt: routedSource.lastReceiptSweepAt,
      routedState: routedSource,
      logEntries: generated.logEntries,
      nextLogSequence: generated.nextLogSequence,
      promptPreview: promptArtifacts.promptPreview,
    };
  }

  function createRefreshAbortError(message = 'Refresh aborted.') {
    const error = new Error(String(message || 'Refresh aborted.'));
    error.sipRefreshAbort = true;
    return error;
  }

  function isRefreshAbortError(error) {
    return Boolean(error && error.sipRefreshAbort);
  }

  function isAutoRefreshRuntimeActive() {
    return Boolean(runtime.activeRefresh && runtime.activeRefresh.source === 'auto');
  }

  function assertRefreshStillActive(token, stage = '') {
    const activeRefresh = runtime.activeRefresh;
    if (!activeRefresh || activeRefresh.token !== token) {
      throw createRefreshAbortError(stage ? `Refresh aborted before ${stage}.` : 'Refresh aborted.');
    }

    if (activeRefresh.signal?.cancelled) {
      const reason = cleanParagraph(activeRefresh.abortReason || 'Refresh aborted.');
      throw createRefreshAbortError(reason || (stage ? `Refresh aborted before ${stage}.` : 'Refresh aborted.'));
    }
  }

  async function setAutoRefreshActivity(state, overrides = {}) {
    const nextState = {
      ...(state || await loadState()),
      autoRefreshActive: Boolean(overrides.active),
      autoRefreshStartedAt: cleanInline(overrides.startedAt || ''),
      autoRefreshContinuityId: sanitizeContinuityId(overrides.continuityId || ''),
      autoRefreshSource: sanitizeAutoRefreshSource(overrides.source || 'auto'),
    };

    return saveState(nextState);
  }

  async function abortActiveAutoRefresh(reason = 'Superseded by a newer user generation request.') {
    const activeRefresh = runtime.activeRefresh;
    if (!activeRefresh || activeRefresh.source !== 'auto') return false;

    const safeReason = cleanParagraph(reason || 'Superseded by a newer user generation request.');
    activeRefresh.abortReason = safeReason;

    try {
      activeRefresh.signal?.cancel();
    } catch (_err) {
    }

    await pushScriptLog('warn', 'Aborted active auto refresh.', safeReason);
    return true;
  }

  async function clearStaleAutoRefreshActivityIfNeeded() {
    const state = await loadState();
    if (!state.autoRefreshActive) return state;

    const clearedState = await setAutoRefreshActivity(state, {
      active: false,
      startedAt: '',
      continuityId: '',
      source: 'auto',
    });

    await pushScriptLog('warn', 'Cleared stale auto-refresh activity marker after script load.');
    return clearedState;
  }

  async function removeAllPanelStorage() {
    await Promise.all([
      api.v1.storyStorage.remove(STORAGE_KEYS.promptFields),
      api.v1.storyStorage.remove(STORAGE_KEYS.currentOutput),
      api.v1.storyStorage.remove(STORAGE_KEYS.generated),
      api.v1.storyStorage.remove(STORAGE_KEYS.promptPreview),
      api.v1.storyStorage.remove(STORAGE_KEYS.routedState),
    ]);
  }

  async function initializeFreshSession() {
    if (runtime.storyGenerationActive) {
      await pushScriptLog('warn', 'Initialization reset skipped because a story turn is already generating.');
      const state = await saveState(await loadState());
      await syncPanel(state);
      return;
    }

    if (runtime.busy || isAutoRefreshRuntimeActive()) {
      await pushScriptLog('warn', 'Initialization reset skipped because a refresh is already active.');
      const state = await saveState(await loadState());
      await syncPanel(state);
      return;
    }

    runtime.busy = false;
    runtime.activeRefresh = null;
    runtime.completedContinuityIds.clear();
    runtime.fullLogViewerText = '';
    runtime.nextRefreshToken = 1;

    await clearEditSession();
    runtime.scriptLogEntries = [];
    await saveScriptLogEntries([]);

    await removeAllPanelStorage();

    let state = await saveState(createDefaultState());
    state.lastStatus = 'Initialization reset complete. Generating a fresh secret-info block...';
    state.lastError = '';
    state = await saveState(state);
    await syncPanel(state);

    await pushScriptLog('info', 'Initialization reset complete.', 'Cleared all Secret Info Panel storage and restored defaults.');
    await refreshSecretInfo('initialize');
  }

  function extractGeneratedTextRaw(response) {
    return String(
      response?.choices?.[0]?.text ??
      response?.choices?.[0]?.message?.content ??
      response?.text ??
      ''
    );
  }

  function extractGeneratedText(response) {
    return cleanParagraph(extractGeneratedTextRaw(response));
  }

  function sanitizeSecretInfo(rawText) {
    const body = sanitizeSecretInfoBody(rawText);
    if (!body) return '';
    return sanitizeStoredSecretInfo(body);
  }

  function containsFirstPersonInnerVoice(secretInfoText) {
    const text = String(secretInfoText || '')
      .replace(/^secret\s+information\s*:\s*/i, '')
      .trim();

    if (!text) return false;

    return /(^|[^a-z])(i|me|my|mine|myself|we|us|our|ours|ourselves)(?=[^a-z]|$)/i.test(text);
  }

  function getDefaultSystemPrompt() {
    return [
      'You create a private continuity note for the author of an ongoing fiction story.',
      'Your job is to infer hidden or semi-hidden character interiority from the current story context plus the previous secret-info block.',
      'Focus on internal reflections, uncertain feelings, emotional undercurrents, guarded reactions, private interpretations, hesitation, attraction, suspicion, rationalization, and shifts in attention or concern.',
      'This is not a public-facing summary and not a recap of obvious surface actions.',
      'Use only supported or strongly implied inferences.',
      'Treat the note as speculative interior reading, not omniscient fact.',
      'Write hidden thoughts and feelings as partial, uncertain, and sometimes self-contradictory.',
      'Characters should often be unsure of what they feel, notice reactions before they can name them, rationalize their behavior, misread themselves, suppress impulses, or hold multiple motives at once.',
      'Write the block like private, half-formed reflection close to lived experience, not like an authoritative psychological diagnosis or polished literary verdict.',
      'Use close third person only: intimate and inward, but still clearly referring to the character as she, he, they, or by name.',
      'Never write in first person and never use I, me, my, mine, we, us, our, or quoted internal monologue.',
      'Keep the wording plain, inward, and low-drama, closer to passing private thought than elegant narration.',
      'Prefer simple inward phrasing over polished prose, metaphor-heavy description, or clever literary flourish.',
      'Do not write as though the character has already been solved.',
      'Do not sound like an outside narrator confidently explaining what the character truly is; stay close to what they might privately sense, tell themselves, or fail to articulate.',
      'Do not turn subtext, attraction, possibility, or a lorebook trait into proof that a character consciously recognizes, names, or fully embraces it unless the story makes that explicit.',
      'Treat hidden tendencies and lorebook information as background pressure, not as solved conclusions.',
      'Prefer gradual recalibration over sudden transformation.',
      'Only strengthen an interpretation when the current scene clearly adds new support for it.',
      'If the new material is modest, keep the update modest.',
      'When the evidence is ambiguous, preserve ambiguity.',
      'Use uncertainty-forward language throughout.',
      'Most sentences should be phrased as impressions, possibilities, suspicions, or partial self-readings rather than flat certainties.',
      'Prefer wording such as may, might, could, seems, appears, likely, perhaps, possibly, feels, wonders, suspects, or similar soft qualifiers.',
      'Write one compact paragraph only.',
      'Begin exactly with: Secret information:',
      'Do not use markdown, bullet points, JSON, headings, or meta commentary.',
    ].join(' ');
  }

  function getDefaultScriptPrompt() {
    return [
      'Update the private continuity note using the live story context already supplied by the editor.',
      'Prefer named characters who matter right now.',
      'Emphasize internal reflections, emotional reactions, guarded interpretations, uncertainty, private attraction or aversion, self-justification, and feelings the characters may not say aloud.',
      'Keep the note human-like: people often think in mixed feelings, passing reactions, half-admissions, defensive framing, and imperfect self-understanding rather than clear conclusions.',
      'Keep the emphasis on what a character may be noticing, resisting, rationalizing, or only partly admitting to themselves.',
      'Anchor every change to what the current turn actually supports.',
      'Keep internal reasoning provisional, evidence-based, and soft rather than absolute, polished, or dramatically resolved.',
      'Keep the voice close to passing private thought: plain, inward, and emotionally grounded rather than elegant, dramatic, or narrator-like.',
      'Write in close third person only, never first person. Keep the subject explicit enough that the note cannot be mistaken for the story narrator or player POV.',
      'Favor ordinary self-justifying phrasing over literary flourish or polished psychological explanation.',
      'Treat hidden tendencies as background pressure, not as a solved conclusion.',
      'Phrase most statements about inner state with soft uncertainty or partiality rather than direct certainty.',
      'Use wording like may, might, could, seems, appears, likely, perhaps, possibly, feels, wonders, suspects, or similar soft qualifiers when describing thoughts or emotions.',
      'Do not present one interaction as a complete psychological shift, final realization, or irreversible change unless the scene unmistakably proves it.',
      'If the prior secret-info block was stronger than the current scene supports, soften it instead of reinforcing it.',
      'Preserve ambiguity when the evidence is ambiguous.',
      'Avoid broad world recap, visible action inventory, or outside-narrator explanation unless it directly matters to a hidden feeling or private interpretation.',
      'Target roughly 90 to 150 words.',
      'Return exactly one paragraph.',
    ].join(' ');
  }

  function buildSystemPrompt(state) {
    return cleanParagraph(state?.scriptSystemPrompt || '') || getDefaultSystemPrompt();
  }

  function buildPromptDynamic({ storyTitle, priorSecretInfo }) {
    const prior = clipText(cleanParagraph(priorSecretInfo || ''), CONFIG.maxPriorChars);

    return [
      storyTitle ? `Story title: ${storyTitle}` : '',
      prior
        ? `Previous secret-info block:\n${prior}`
        : 'Previous secret-info block:\n(none yet)',
    ].filter(Boolean).join('\n\n');
  }

  function getPromptSeedSecretInfo(state) {
    const storyTurnCounter = sanitizeTurnCounter(state?.storyTurnCounter);
    const promptSeedTurnCounter = sanitizePromptSeedTurnCounter(state?.promptSeedTurnCounter);
    const promptSeedSecretInfo = sanitizePriorSecretInfo(state?.promptSeedSecretInfo || '');
    const currentSecretInfo = sanitizePriorSecretInfo(state?.secretInfo || '');

    if (promptSeedTurnCounter === storyTurnCounter) {
      return promptSeedSecretInfo;
    }

    return currentSecretInfo;
  }

  function ensurePromptSeedForCurrentTurn(state) {
    const currentState = state || {};
    const storyTurnCounter = sanitizeTurnCounter(currentState.storyTurnCounter);
    const promptSeedTurnCounter = sanitizePromptSeedTurnCounter(currentState.promptSeedTurnCounter);

    if (promptSeedTurnCounter === storyTurnCounter) {
      return {
        ...currentState,
        storyTurnCounter,
        promptSeedTurnCounter,
        promptSeedSecretInfo: sanitizePriorSecretInfo(currentState.promptSeedSecretInfo || ''),
      };
    }

    return {
      ...currentState,
      storyTurnCounter,
      promptSeedTurnCounter: storyTurnCounter,
      promptSeedSecretInfo: sanitizePriorSecretInfo(currentState.secretInfo || ''),
    };
  }

  // -----------------------------
  // Prompt Engine Module
  // -----------------------------
  function derivePromptArtifacts({ scriptSystemPrompt, scriptPrompt, storyTitle, priorSecretInfo }) {
    const systemPrompt = cleanParagraph(scriptSystemPrompt || '') || getDefaultSystemPrompt();
    const taskPrompt = cleanParagraph(scriptPrompt || '') || getDefaultScriptPrompt();
    const promptDynamic = buildPromptDynamic({
      storyTitle,
      priorSecretInfo,
    });
    const promptPreview = buildPromptPreviewFromParts({
      scriptSystemPrompt: systemPrompt,
      promptDynamic,
      scriptPrompt: taskPrompt,
    });

    return {
      systemPrompt,
      taskPrompt,
      promptDynamic,
      promptPreview,
    };
  }

  function parsePromptPreview(previewText) {
    const preview = String(previewText || '').replace(/\r/g, '').trim();
    const systemPrefix = 'SYSTEM:\n';
    const userMarker = '\n\nUSER:\n';

    if (!preview.startsWith(systemPrefix)) {
      throw new Error('Prompt preview is missing the SYSTEM: header.');
    }

    const remainder = preview.slice(systemPrefix.length);
    const splitIndex = remainder.indexOf(userMarker);
    if (splitIndex === -1) {
      throw new Error('Prompt preview is missing the USER: header.');
    }

    const systemPrompt = cleanParagraph(remainder.slice(0, splitIndex));
    const userPrompt = cleanParagraph(remainder.slice(splitIndex + userMarker.length));

    if (!systemPrompt) {
      throw new Error('Prompt preview produced an empty system prompt.');
    }

    if (!userPrompt) {
      throw new Error('Prompt preview produced an empty user prompt.');
    }

    return [
      {
        role: 'system',
        content: systemPrompt,
      },
      {
        role: 'user',
        content: userPrompt,
      },
    ];
  }

  function buildScriptPrompt(state) {
    return cleanParagraph(state?.scriptPrompt || '') || getDefaultScriptPrompt();
  }

  function buildUserPrompt({ state, storyTitle, priorSecretInfo }) {
    return [
      buildPromptDynamic({ storyTitle, priorSecretInfo }),
      buildScriptPrompt(state),
    ].filter(Boolean).join('\n\n');
  }

  function buildPromptPreviewFromParts({ scriptSystemPrompt, promptDynamic, scriptPrompt }) {
    const systemPrompt = cleanParagraph(scriptSystemPrompt || '') || getDefaultSystemPrompt();
    const dynamicText = cleanParagraph(promptDynamic || '');
    const taskPrompt = cleanParagraph(scriptPrompt || '') || getDefaultScriptPrompt();

    return clipText(
      [
        `SYSTEM:\n${systemPrompt}`,
        `USER:\n${[dynamicText, taskPrompt].filter(Boolean).join('\n\n')}`,
      ].join('\n\n'),
      CONFIG.maxPromptChars
    );
  }

  function getSafeMaxTokens(requested) {
    const desired = Number.isFinite(requested) ? Math.floor(requested) : CONFIG.maxTokens;
    let safe = Math.max(CONFIG.minAllowedOutputTokens, desired);

    try {
      const allowed = api.v1.script?.getAllowedOutput?.();
      if (Number.isFinite(allowed) && allowed > 0) {
        safe = Math.min(safe, Math.floor(allowed));
      }
    } catch (_err) {
    }

    return safe;
  }

  function appendLogEntry(state, { secretInfo, source, storyTitle, updatedAt }) {
    const entries = sanitizeLogEntries(state.logEntries, state.maxHistoryEntries);
    const previous = entries.length ? entries[entries.length - 1] : null;
    const currentTurnCounter = sanitizeTurnCounter(state.storyTurnCounter);
    const entry = {
      sequence: Number.isFinite(state.nextLogSequence) ? Math.max(1, Math.floor(state.nextLogSequence)) : (entries.length + 1),
      updatedAt: cleanInline(updatedAt || formatTimestamp()),
      storyTitle: cleanInline(storyTitle || ''),
      source: cleanInline(source || 'manual'),
      turnCounter: currentTurnCounter,
      changedFromPrevious: previous ? previous.turnCounter !== currentTurnCounter : true,
      secretInfo: sanitizeStoredSecretInfo(secretInfo || ''),
    };

    const nextEntries = [...entries, entry].slice(-sanitizeHistoryLimit(state.maxHistoryEntries));
    return {
      ...state,
      logEntries: nextEntries,
      nextLogSequence: entry.sequence + 1,
    };
  }

  function getAllLogEntries(state) {
    return sanitizeLogEntries(state.logEntries, state.maxHistoryEntries).slice().reverse();
  }

  function getVisibleLogEntries(state) {
    return getAllLogEntries(state).slice(0, 4);
  }

  function buildLogText(state) {
    const entries = getAllLogEntries(state);
    if (!entries.length) return 'No recent log entries yet. Refresh the panel after each turn to build a running history.';

    return entries
      .map((entry) => {
        const header = [
          `Entry ${String(entry.sequence).padStart(3, '0')}`,
          entry.updatedAt || 'Unknown time',
          entry.source || 'manual',
          entry.changedFromPrevious ? 'changed' : 'unchanged',
        ].join(' | ');

        const lines = [header];
        if (entry.storyTitle) lines.push(`Story: ${entry.storyTitle}`);
        lines.push(entry.secretInfo || '(empty)');
        return lines.join('\n');
      })
      .join('\n\n----------------------------------------\n\n');
  }

  function buildEntryTitle(entry) {
    return [
      `Entry ${String(entry.sequence).padStart(3, '0')}`,
      entry.updatedAt || 'Unknown time',
      entry.source || 'manual',
      entry.changedFromPrevious ? 'changed' : 'unchanged',
    ].join(' | ');
  }

  function getLogEntryHeight(secretInfo) {
    const length = String(secretInfo || '').length;
    if (length > 1800) return 200;
    if (length > 1200) return 170;
    if (length > 700) return 140;
    return CONFIG.historyEntryMinHeight;
  }

  function buildLogEntryParts(state, options = {}) {
    const { text, codeEditor, collapsibleSection } = api.v1.ui.part;
    const entries = options.showAll ? getAllLogEntries(state) : getVisibleLogEntries(state);

    if (!entries.length) {
      return [
        text({
          text: 'No recent log entries yet. Refresh the panel after each turn to build a running history.',
        }),
      ];
    }

    return entries.map((entry, index) => {
      const section = {
        id: `sip-v2-log-entry-${entry.sequence}`,
        title: buildEntryTitle(entry),
        initialCollapsed: true,
        content: [
          text({
            text: `Story: ${entry.storyTitle || '--'}`,
          }),
          codeEditor({
            id: `sip-v2-log-entry-editor-${entry.sequence}`,
            language: 'plaintext',
            initialValue: entry.secretInfo || '(empty)',
            height: getLogEntryHeight(entry.secretInfo),
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      };

      if (index < 4) {
        section.storageKey = `sip-v2-log-entry-collapsed-slot-${index}`;
      }

      return collapsibleSection(section);
    });
  }

  function getFullLogViewerText(state) {
    return runtime.fullLogViewerText || 'Press "Populate Recent Log Box" to load the 4 most recent stored log entries into this viewer.';
  }

  function getPromptViewerText(state) {
    const storyTitle = cleanInline(state?.lastStoryTitle || '');
    const secretInfo = clipText(cleanParagraph(state?.secretInfo || ''), CONFIG.maxStoredChars);
    const promptArtifacts = derivePromptArtifacts({
      scriptSystemPrompt: state?.scriptSystemPrompt,
      scriptPrompt: state?.scriptPrompt,
      storyTitle,
      priorSecretInfo: getPromptSeedSecretInfo({
        ...state,
        secretInfo,
      }),
    });

    const stored = cleanParagraph(state?.promptPreview || '');
    if (stored) return clipText(stored, CONFIG.maxPromptChars);

    return promptArtifacts.promptPreview;
  }

  function getSystemPromptViewerText(state) {
    const prompt = cleanParagraph(state?.scriptSystemPrompt || '');
    return prompt || getDefaultSystemPrompt();
  }

  function getScriptPromptViewerText(state) {
    const prompt = cleanParagraph(state?.scriptPrompt || '');
    return prompt || getDefaultScriptPrompt();
  }

  // -----------------------------
  // Diagnostics Module
  // -----------------------------
  function buildRouteAdapterSummary(routedState) {
    const source = routedState && typeof routedState === 'object' ? routedState : createDefaultRoutedState();
    const targets = sanitizeRoutedTargets(source.targets);
    const parts = [];

    for (const name of ROUTE_TARGET_NAMES) {
      const target = targets[name];
      parts.push(`${target.targetLabel}:${target.adapterVersion}:${target.fragmentKey}`);
    }

    return parts.join(' | ');
  }

  function buildRouteReceiptSummary(routedState) {
    const source = routedState && typeof routedState === 'object' ? routedState : createDefaultRoutedState();
    const targets = sanitizeRoutedTargets(source.targets);
    const parts = [];

    for (const name of ROUTE_TARGET_NAMES) {
      const target = targets[name];
      parts.push(`${target.targetLabel}:${target.receiptStatus}:${target.ownershipStatus}`);
    }

    return parts.join(' | ');
  }

  function getDiagnosticsSnapshot(state) {
    const entries = sanitizeLogEntries(state.logEntries, state.maxHistoryEntries);
    const lastEntry = entries.length ? entries[entries.length - 1] : null;
    const rawResponseLayers = deriveRawResponseLayers(state);
    const canonicalLayers = deriveCanonicalLayers(state);
    const currentSecretInfo = canonicalLayers.derivedDisplayText;
    const storyTitle = cleanInline(state.lastStoryTitle || '');
    const promptArtifacts = derivePromptArtifacts({
      scriptSystemPrompt: state.scriptSystemPrompt,
      scriptPrompt: state.scriptPrompt,
      storyTitle,
      priorSecretInfo: getPromptSeedSecretInfo(state),
    });
    const storedPromptPreview = cleanParagraph(state.promptPreview || '');
    const effectivePromptPreview = storedPromptPreview || promptArtifacts.promptPreview;
    const promptPreviewInSync = !storedPromptPreview || storedPromptPreview === promptArtifacts.promptPreview;
    const latestLogMatchesCurrent = lastEntry ? cleanParagraph(lastEntry.secretInfo || '') === currentSecretInfo : false;
    const warnings = [];

    if (!currentSecretInfo) warnings.push('Current secret-info output is empty.');
    if (!cleanParagraph(state.scriptSystemPrompt || '')) warnings.push('Script System Prompt is empty.');
    if (!cleanParagraph(state.scriptPrompt || '')) warnings.push('Script Prompt is empty.');
    if (!storyTitle) warnings.push('Story title is empty.');
    if (!promptPreviewInSync) warnings.push('Stored prompt preview is out of sync with current inputs.');
    if (entries.length && !latestLogMatchesCurrent) warnings.push('Current output differs from the newest stored history entry.');
    if (cleanParagraph(state.lastError || '')) warnings.push('Last refresh recorded an error.');
    if (!entries.length) warnings.push('No history entries have been stored yet.');

    return {
      status: state.lastStatus || 'Idle.',
      busy: runtime.busy,
      lastUpdatedAt: state.lastUpdatedAt || '--',
      model: state.lastModel || CONFIG.model,
      storyTitle: storyTitle || '--',
      currentOutputChars: currentSecretInfo.length,
      canonicalBodyChars: canonicalLayers.canonicalBody.length,
      displayTextChars: canonicalLayers.derivedDisplayText.length,
      rawResponseChars: rawResponseLayers.rawResponseText.length,
      rawResponseBodyChars: rawResponseLayers.rawResponseBody.length,
      promptPreviewChars: effectivePromptPreview.length,
      dynamicPromptChars: promptArtifacts.promptDynamic.length,
      historyCount: entries.length,
      historyMax: sanitizeHistoryLimit(state.maxHistoryEntries),
      latestLogSequence: lastEntry?.sequence || 0,
      latestLogChanged: lastEntry ? Boolean(lastEntry.changedFromPrevious) : false,
      latestLogMatchesCurrent,
      promptPreviewInSync,
      warnings,
      autoRefreshActive: Boolean(state.autoRefreshActive),
      autoRefreshStartedAt: cleanInline(state.autoRefreshStartedAt || ''),
      autoRefreshContinuityId: sanitizeContinuityId(state.autoRefreshContinuityId || ''),
      canonicalContractVersion: CANONICAL_CONTRACT_VERSION,
      adapterContractVersion: cleanInline(state.adapterContractVersion || state.routedState?.adapterContractVersion || '') || ROUTE_ADAPTER_CONTRACT_VERSION,
      routedFragmentStatus: cleanInline(state.routedFragmentStatus || '') || ROUTE_LAYER_STATUS,
      routingReceiptStatus: cleanInline(state.routingReceiptStatus || '') || ROUTE_LAYER_STATUS,
      routeAdapterSummary: buildRouteAdapterSummary(state.routedState),
      routeReceiptSummary: buildRouteReceiptSummary(state.routedState),
      routePlannerSummary: buildRoutePlannerSummary(state.routedState),
      lastReceiptSweepAt: cleanInline(state.lastReceiptSweepAt || state.routedState?.lastReceiptSweepAt || ''),
      lastError: cleanParagraph(state.lastError || ''),
      rawResponsePreview: clipText(rawResponseLayers.rawResponseText || '', 900),
      canonicalBodyPreview: clipText(canonicalLayers.canonicalBody || '', 900),
      displayTextPreview: clipText(canonicalLayers.derivedDisplayText || '', 900),
      promptDynamicPreview: clipText(state.lastPromptDynamic || promptArtifacts.promptDynamic || '', 1200),
      validationNotes: [
        `Prompt preview in sync: ${promptPreviewInSync ? 'yes' : 'no'}`,
        `Latest history entry matches current output: ${entries.length ? (latestLogMatchesCurrent ? 'yes' : 'no') : 'n/a'}`,
        `History entries stored: ${entries.length} / ${sanitizeHistoryLimit(state.maxHistoryEntries)}`,
        `Raw response captured: ${cleanParagraph(state.lastRawResponse || '') ? 'yes' : 'no'}`,
      ].join('\n'),
    };
  }

  function buildDiagnosticsParts(state) {
    const { text, codeEditor, collapsibleSection } = api.v1.ui.part;
    const diagnostics = getDiagnosticsSnapshot(state);
    const runState = runtime.busy
      ? 'refresh-running'
      : (runtime.storyGenerationActive ? 'story-generation' : 'idle');
    const warningsText = diagnostics.warnings.length
      ? diagnostics.warnings.join(' ')
      : 'None';
    const checksText = [
      `Prompt sync: ${diagnostics.promptPreviewInSync ? 'ok' : 'mismatch'}`,
      `Latest output: ${diagnostics.historyCount ? (diagnostics.latestLogMatchesCurrent ? 'matches history' : 'differs from history') : 'not logged yet'}`,
      `Auto refresh: ${diagnostics.autoRefreshActive ? 'active' : 'idle'}${diagnostics.autoRefreshStartedAt ? ` | Started: ${diagnostics.autoRefreshStartedAt}` : ''}${diagnostics.autoRefreshContinuityId ? ` | Turn: ${diagnostics.autoRefreshContinuityId}` : ''}`,
    ].join('\\n');
    const contractsText = [
      `Canonical contract: ${diagnostics.canonicalContractVersion}`,
      `Adapter contract: ${diagnostics.adapterContractVersion}`,
      `Routed fragments: ${diagnostics.routedFragmentStatus}`,
      `Routing receipts: ${diagnostics.routingReceiptStatus}`,
    ].join('\\n');
    const routingText = [
      `Adapters: ${diagnostics.routeAdapterSummary}`,
      `Receipts: ${diagnostics.routeReceiptSummary}${diagnostics.lastReceiptSweepAt ? ` | Sweep: ${diagnostics.lastReceiptSweepAt}` : ''}`,
      `Planner: ${diagnostics.routePlannerSummary}`,
    ].join('\\n');

    return [
      text({
        text: `Run: ${runState} | Status: ${diagnostics.status}`,
      }),
      text({
        text: `Story: ${diagnostics.storyTitle}`,
      }),
      text({
        text: `Output: ${diagnostics.currentOutputChars} chars | Prompt: ${diagnostics.promptPreviewChars} chars`,
      }),
      text({
        text: `History: ${diagnostics.historyCount} / ${diagnostics.historyMax} | Latest: ${diagnostics.latestLogSequence || '--'}`,
      }),
      text({
        text: `Warnings: ${warningsText}`,
      }),
      collapsibleSection({
        id: 'sip-v2-diagnostics-checks',
        title: 'Checks',
        initialCollapsed: true,
        storageKey: 'sip-v2-diagnostics-checks-collapsed',
        content: [
          codeEditor({
            id: 'sip-v2-diagnostics-checks-editor',
            language: 'plaintext',
            initialValue: checksText,
            height: 110,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
      collapsibleSection({
        id: 'sip-v2-diagnostics-contracts',
        title: 'Contracts',
        initialCollapsed: true,
        storageKey: 'sip-v2-diagnostics-contracts-collapsed',
        content: [
          codeEditor({
            id: 'sip-v2-diagnostics-contracts-editor',
            language: 'plaintext',
            initialValue: contractsText,
            height: 110,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
      collapsibleSection({
        id: 'sip-v2-diagnostics-routing',
        title: 'Routing',
        initialCollapsed: true,
        storageKey: 'sip-v2-diagnostics-routing-collapsed',
        content: [
          codeEditor({
            id: 'sip-v2-diagnostics-routing-editor',
            language: 'plaintext',
            initialValue: routingText,
            height: 140,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
      collapsibleSection({
        id: 'sip-v2-diagnostics-last-error',
        title: 'Last Error',
        initialCollapsed: true,
        storageKey: 'sip-v2-diagnostics-last-error-collapsed',
        content: [
          codeEditor({
            id: 'sip-v2-diagnostics-last-error-editor',
            language: 'plaintext',
            initialValue: diagnostics.lastError || 'No error recorded.',
            height: diagnostics.lastError ? 120 : 70,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
      collapsibleSection({
        id: 'sip-v2-diagnostics-raw-response',
        title: 'Last Raw Response',
        initialCollapsed: true,
        storageKey: 'sip-v2-diagnostics-raw-response-collapsed',
        content: [
          text({ text: `Captured: ${diagnostics.rawResponseChars} chars` }),
          codeEditor({
            id: 'sip-v2-diagnostics-raw-response-editor',
            language: 'plaintext',
            initialValue: diagnostics.rawResponsePreview || 'No raw response captured yet.',
            height: diagnostics.rawResponsePreview ? 180 : 70,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
      collapsibleSection({
        id: 'sip-v2-diagnostics-prompt-dynamic',
        title: 'Last Prompt Dynamic Block',
        initialCollapsed: true,
        storageKey: 'sip-v2-diagnostics-prompt-dynamic-collapsed',
        content: [
          codeEditor({
            id: 'sip-v2-diagnostics-prompt-dynamic-editor',
            language: 'plaintext',
            initialValue: diagnostics.promptDynamicPreview || 'No prompt dynamic block has been built yet.',
            height: diagnostics.promptDynamicPreview ? 180 : 70,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
      collapsibleSection({
        id: 'sip-v2-diagnostics-validation',
        title: 'Validation Notes',
        initialCollapsed: true,
        storageKey: 'sip-v2-diagnostics-validation-collapsed',
        content: [
          codeEditor({
            id: 'sip-v2-diagnostics-validation-editor',
            language: 'plaintext',
            initialValue: diagnostics.validationNotes,
            height: 110,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
    ];
  }


  function getWorkspaceTabOptions() {
    return [
      { key: 'secretInfo', label: 'Secret Info' },
      { key: 'prompting', label: 'Prompting' },
      { key: 'planning', label: 'Planning' },
      { key: 'history', label: 'History' },
    ];
  }

  function sanitizeWorkspaceTab(value) {
    const key = cleanInline(value || '');
    return getWorkspaceTabOptions().some((tab) => tab.key === key) ? key : 'secretInfo';
  }

  async function loadWorkspaceTabFromTemp() {
    const stored = await api.v1.tempStorage.get(TEMP_EDIT_STATE_KEYS.workspaceTab);
    runtime.workspaceTab = sanitizeWorkspaceTab(stored);
    return runtime.workspaceTab;
  }

  async function persistWorkspaceTabToTemp() {
    const nextTab = sanitizeWorkspaceTab(runtime.workspaceTab);
    runtime.workspaceTab = nextTab;
    await api.v1.tempStorage.set(TEMP_EDIT_STATE_KEYS.workspaceTab, nextTab);
    return nextTab;
  }

  async function setWorkspaceTab(tabKey) {
    runtime.workspaceTab = sanitizeWorkspaceTab(tabKey);
    await persistWorkspaceTabToTemp();
    const state = await loadState();
    await syncPanel(state);
  }

  function getDraftStorageKey(field) {
    switch (field) {
      case EDIT_FIELDS.secretInfo:
        return TEMP_EDIT_STATE_KEYS.secretInfoDraft;
      case EDIT_FIELDS.scriptSystemPrompt:
        return TEMP_EDIT_STATE_KEYS.systemPromptDraft;
      case EDIT_FIELDS.scriptPrompt:
        return TEMP_EDIT_STATE_KEYS.scriptPromptDraft;
      default:
        return '';
    }
  }

  async function loadEditSessionFromTemp() {
    const activeField = await api.v1.tempStorage.get(TEMP_EDIT_STATE_KEYS.activeField);
    runtime.editSession.activeField = activeField && Object.values(EDIT_FIELDS).includes(activeField) ? activeField : '';
    runtime.editSession.draftValue = '';

    if (runtime.editSession.activeField) {
      const draftKey = getDraftStorageKey(runtime.editSession.activeField);
      if (draftKey) {
        runtime.editSession.draftValue = String((await api.v1.tempStorage.get(draftKey)) || '');
      }
    }
  }

  async function persistEditSessionToTemp() {
    clearDraftPersistTimer();
    if (runtime.editSession.activeField) {
      await api.v1.tempStorage.set(TEMP_EDIT_STATE_KEYS.activeField, runtime.editSession.activeField);
      const draftKey = getDraftStorageKey(runtime.editSession.activeField);
      if (draftKey) {
        await api.v1.tempStorage.set(draftKey, String(runtime.editSession.draftValue || ''));
      }
      return;
    }

    await clearEditSessionTempState();
  }

  async function clearEditSessionTempState() {
    clearDraftPersistTimer();
    await Promise.all([
      api.v1.tempStorage.remove(TEMP_EDIT_STATE_KEYS.activeField),
      api.v1.tempStorage.remove(TEMP_EDIT_STATE_KEYS.secretInfoDraft),
      api.v1.tempStorage.remove(TEMP_EDIT_STATE_KEYS.systemPromptDraft),
      api.v1.tempStorage.remove(TEMP_EDIT_STATE_KEYS.scriptPromptDraft),
    ]);
  }

  function clearDraftPersistTimer() {
    if (!runtime.editSession.persistTimerId) return;
    clearTimeout(runtime.editSession.persistTimerId);
    runtime.editSession.persistTimerId = null;
  }

  function scheduleDraftPersist() {
    clearDraftPersistTimer();
    runtime.editSession.persistToken += 1;
    const expectedToken = runtime.editSession.persistToken;
    runtime.editSession.persistTimerId = setTimeout(async () => {
      runtime.editSession.persistTimerId = null;
      if (expectedToken !== runtime.editSession.persistToken) return;
      if (!runtime.editSession.activeField) return;
      const draftKey = getDraftStorageKey(runtime.editSession.activeField);
      if (!draftKey) return;
      try {
        await api.v1.tempStorage.set(draftKey, String(runtime.editSession.draftValue || ''));
      } catch (_err) {
      }
    }, EDIT_DRAFT_PERSIST_DEBOUNCE_MS);
  }

  async function updateEditSessionDraft(value) {
    if (runtime.storyGenerationActive) return;
    runtime.editSession.draftValue = String(value || '');
    if (!runtime.editSession.activeField) return;
    const draftKey = getDraftStorageKey(runtime.editSession.activeField);
    if (!draftKey) return;
    scheduleDraftPersist();
  }

  function getEditFieldLabel(field) {
    switch (field) {
      case EDIT_FIELDS.secretInfo:
        return 'Secret Information Output';
      case EDIT_FIELDS.scriptSystemPrompt:
        return 'Script System Prompt';
      case EDIT_FIELDS.scriptPrompt:
        return 'Script Prompt';
      default:
        return 'Field';
    }
  }

  function hasActiveEditSession() {
    return Boolean(runtime.editSession?.activeField);
  }

  function isEditingField(field) {
    return runtime.editSession?.activeField === field;
  }

  function isPanelInteractionLocked() {
    return runtime.storyGenerationActive || runtime.busy;
  }

  function getPanelLockReasonText() {
    if (runtime.storyGenerationActive) return 'the current story turn to finish';
    if (runtime.busy) return 'the current refresh to finish';
    return '';
  }

  async function toastPanelLocked(actionText = 'using the Secret Info panel') {
    const reasonText = getPanelLockReasonText();
    if (!reasonText) return;
    await api.v1.ui.toast(`Wait for ${reasonText} before ${actionText}.`);
  }

  function shouldTrackStoryGeneration(params) {
    return Boolean(params?.continuityId) && !params?.inlineGeneration && !params?.toolboxMode && !params?.scriptInitiated;
  }

  async function clearEditSession() {
    runtime.editSession.activeField = '';
    runtime.editSession.draftValue = '';
    await clearEditSessionTempState();
  }

  function getEditableFieldValue(field, state) {
    switch (field) {
      case EDIT_FIELDS.secretInfo:
        return sanitizeSecretInfoBody(state?.secretInfo || '');
      case EDIT_FIELDS.scriptSystemPrompt:
        return getSystemPromptViewerText(state);
      case EDIT_FIELDS.scriptPrompt:
        return getScriptPromptViewerText(state);
      default:
        return '';
    }
  }

  function getEditableFieldDraft(field, state) {
    if (isEditingField(field)) {
      return String(runtime.editSession?.draftValue || '');
    }

    return getEditableFieldValue(field, state);
  }

  async function beginEditSession(field) {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('editing.');
      return;
    }

    if (hasActiveEditSession() && !isEditingField(field)) {
      await api.v1.ui.toast(`Finish editing ${getEditFieldLabel(runtime.editSession.activeField)} first.`);
      return;
    }

    const state = await loadState();
    runtime.editSession.activeField = field;
    runtime.editSession.draftValue = getEditableFieldValue(field, state);
    await persistEditSessionToTemp();
    await pushScriptLog('info', 'Started edit session.', `field=${field}`);
    await syncPanel(state);
  }

  async function cancelEditSession() {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('changing edit state.');
      return;
    }

    const activeField = runtime.editSession.activeField;
    if (!activeField) return;

    await clearEditSession();
    const state = await loadState();
    state.lastStatus = `Canceled editing for ${getEditFieldLabel(activeField)}.`;
    state.lastError = '';
    await pushScriptLog('info', 'Canceled edit session.', `field=${activeField}`);
    await syncPanel(state);
  }

  async function resetEditSessionDraftToDefault(field) {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('resetting editor drafts.');
      return;
    }

    if (!isEditingField(field)) return;

    if (field === EDIT_FIELDS.scriptSystemPrompt) {
      await updateEditSessionDraft(getDefaultSystemPrompt());
    } else if (field === EDIT_FIELDS.scriptPrompt) {
      await updateEditSessionDraft(getDefaultScriptPrompt());
    } else {
      return;
    }

    const state = await loadState();
    await syncPanel(state);
  }

  async function saveEditSession(field) {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('saving edits.');
      return;
    }

    if (!isEditingField(field)) return;

    let state = await loadState();
    const draftValue = String(runtime.editSession.draftValue || '');
    const updatedAt = formatTimestamp();

    if (field === EDIT_FIELDS.secretInfo) {
      const previousCanonicalBody = sanitizeSecretInfoBody(state.canonicalBody || state.secretInfo || '');
      state = commitCanonicalOutput(state, draftValue);
      const nextCanonicalBody = state.canonicalBody;
      const nextDerivedDisplayText = state.derivedDisplayText;
      state.lastUpdatedAt = updatedAt;
      state.lastStatus = nextCanonicalBody
        ? 'Saved manual edits to the secret-info block.'
        : 'Saved manual edits and cleared the secret-info block.';
      state.lastError = '';

      if (nextDerivedDisplayText && nextCanonicalBody !== previousCanonicalBody) {
        state = appendLogEntry(state, {
          secretInfo: nextDerivedDisplayText,
          source: 'manual-edit',
          storyTitle: state.lastStoryTitle,
          updatedAt,
        });
      }

      state = await saveState(state);
      await clearEditSession();
      await pushScriptLog('info', 'Saved manual edit.', `field=${field} changed=${nextCanonicalBody !== previousCanonicalBody}`);
      await syncPanel(state);
      await api.v1.ui.toast('Saved Secret Information Output edits.');
      return;
    }

    if (field === EDIT_FIELDS.scriptSystemPrompt) {
      state.scriptSystemPrompt = cleanParagraph(draftValue || '') || getDefaultSystemPrompt();
      state.lastStatus = 'Saved Script System Prompt edits.';
      state.lastError = '';
      state = await saveState(state);
      await clearEditSession();
      await pushScriptLog('info', 'Saved manual edit.', `field=${field}`);
      await syncPanel(state);
      await api.v1.ui.toast('Saved Script System Prompt edits.');
      return;
    }

    if (field === EDIT_FIELDS.scriptPrompt) {
      state.scriptPrompt = cleanParagraph(draftValue || '') || getDefaultScriptPrompt();
      state.lastStatus = 'Saved Script Prompt edits.';
      state.lastError = '';
      state = await saveState(state);
      await clearEditSession();
      await pushScriptLog('info', 'Saved manual edit.', `field=${field}`);
      await syncPanel(state);
      await api.v1.ui.toast('Saved Script Prompt edits.');
    }
  }

  // -----------------------------
  // Panel UI Module
  // -----------------------------
  function buildEditControls(field, interactionsLocked, hasEditSession, { allowResetToDefault = false } = {}) {
    const { row, button } = api.v1.ui.part;
    const editing = isEditingField(field);
    const disabled = interactionsLocked || (hasEditSession && !editing);

    if (editing) {
      const controls = [
        button({
          text: 'Save',
          disabled: interactionsLocked,
          callback: async () => {
            await saveEditSession(field);
          },
        }),
        button({
          text: 'Cancel',
          disabled: interactionsLocked,
          callback: async () => {
            await cancelEditSession();
          },
        }),
      ];

      if (allowResetToDefault) {
        controls.push(
          button({
            text: 'Reset to Default',
            disabled: interactionsLocked,
            callback: async () => {
              await resetEditSessionDraftToDefault(field);
            },
          })
        );
      }

      return row({ content: controls });
    }

    return row({
      content: [
        button({
          text: 'Edit',
          disabled,
          callback: async () => {
            await beginEditSession(field);
          },
        }),
      ],
    });
  }

  function buildSidebarContent(state) {
    const { column, text } = api.v1.ui.part;
    const hasEditSession = hasActiveEditSession();
    const editField = runtime.editSession.activeField;
    const editStatus = runtime.storyGenerationActive
      ? 'Locked'
      : (hasEditSession ? getEditFieldLabel(editField) : 'None');
    const statusText = runtime.busy
      ? 'Refreshing...'
      : runtime.storyGenerationActive
        ? 'Turn running...'
        : (state.lastStatus || 'Idle.');

    return [
      column({
        spacing: 'start',
        content: [
          text({
            markdown: true,
            text: `**${CONFIG.sidebarName}**`,
          }),
          text({ text: `Status: ${statusText}` }),
          text({ text: `Edit: ${editStatus}` }),
          state.lastUpdatedAt
            ? text({ text: `Updated: ${state.lastUpdatedAt}` })
            : text({ text: 'Updated: --' }),
          text({ markdown: true, text: '**Routes**' }),
          text({ text: buildRoutePlannerSummary(state.routedState) }),
          text({ markdown: true, text: '**Diagnostics**' }),
          ...buildDiagnosticsParts(state),
        ],
      }),
    ];
  }

  function buildRoutePlannerParts(state, interactionsLocked, hasEditSession) {
    const { column, text, checkboxInput } = api.v1.ui.part;
    const targets = state.routedState?.targets || {};

    return ROUTE_TARGET_NAMES.map((name) => {
      const target = targets[name] || createDefaultRoutedTargetState(name);
      return column({
        spacing: 'start',
        content: [
          text({ markdown: true, text: `**${target.targetLabel}**` }),
          checkboxInput({
            id: `sip-v2-route-enable-${name}`,
            initialValue: Boolean(target.enabled),
            label: `Plan ${target.targetLabel}`,
            disabled: interactionsLocked || hasEditSession,
            onChange: async (value) => {
              await setRouteTargetEnabled(name, value);
            },
          }),
          text({ text: `Plan: ${target.planStatus} | Receipt: ${target.receiptStatus} | Ownership: ${target.ownershipStatus}` }),
        ],
      });
    });
  }

  function buildSourcePlanningParts(state, interactionsLocked, hasEditSession) {
    const { column, text, checkboxInput } = api.v1.ui.part;

    return [
      column({
        spacing: 'start',
        content: [
          text({ markdown: true, text: '**Sources**' }),
          text({ text: 'Prefer lorebooks. Turn off for story fallback.' }),
          checkboxInput({
            id: 'sip-v2-source-lorebook-only',
            initialValue: Boolean(state.lorebookOnlyCharacterDetection),
            label: 'Lorebooks only',
            disabled: interactionsLocked || hasEditSession,
            onChange: async (value) => {
              await setLorebookOnlyCharacterDetection(value);
            },
          }),
          text({
            text: state.lorebookOnlyCharacterDetection
              ? 'Mode: lorebooks only.'
              : 'Mode: lorebooks preferred with story fallback.',
          }),
        ],
      }),
    ];
  }

  function buildScriptPanelContent(state) {
    const { column, text, codeEditor, row, button, checkboxInput, container } = api.v1.ui.part;
    const hasEditSession = hasActiveEditSession();
    const interactionsLocked = isPanelInteractionLocked();
    const secretEditorValue = getEditableFieldDraft(EDIT_FIELDS.secretInfo, state);
    const systemPromptEditorValue = getEditableFieldDraft(EDIT_FIELDS.scriptSystemPrompt, state);
    const scriptPromptEditorValue = getEditableFieldDraft(EDIT_FIELDS.scriptPrompt, state);
    const currentTab = sanitizeWorkspaceTab(runtime.workspaceTab);
    const editNotice = runtime.storyGenerationActive
      ? 'Read-only during story generation.'
      : hasEditSession
        ? `Editing ${getEditFieldLabel(runtime.editSession.activeField)}. Save or Cancel before switching tabs or refreshing.`
        : 'No active edit.';

    let tabContent = [];

    if (currentTab === 'secretInfo') {
      tabContent = [
        text({ markdown: true, text: '**Secret Info Body**' }),
        text({ text: 'Body only. The label is derived on save.' }),
        codeEditor({
          id: UI_IDS.secretEditor,
          language: 'plaintext',
          initialValue: secretEditorValue,
          height: CONFIG.secretEditorHeight,
          readOnly: runtime.storyGenerationActive || !isEditingField(EDIT_FIELDS.secretInfo),
          onChange: runtime.storyGenerationActive
            ? undefined
            : isEditingField(EDIT_FIELDS.secretInfo)
              ? (value) => { void updateEditSessionDraft(value); }
              : undefined,
          lineNumbers: false,
          wordWrap: true,
          fontSize: 12,
        }),
        buildEditControls(EDIT_FIELDS.secretInfo, interactionsLocked, hasEditSession),
        row({
          content: [
            button({
              id: UI_IDS.clearButton,
              text: 'Clear Block',
              disabled: interactionsLocked || hasEditSession,
              callback: async () => {
                await clearSecretInfo();
              },
            }),
          ],
        }),
      ];
    } else if (currentTab === 'prompting') {
      tabContent = [
        text({ markdown: true, text: '**System Prompt**' }),
        codeEditor({
          id: UI_IDS.systemPromptEditor,
          language: 'plaintext',
          initialValue: systemPromptEditorValue,
          height: CONFIG.promptEditorHeight,
          readOnly: runtime.storyGenerationActive || !isEditingField(EDIT_FIELDS.scriptSystemPrompt),
          onChange: runtime.storyGenerationActive
            ? undefined
            : isEditingField(EDIT_FIELDS.scriptSystemPrompt)
              ? (value) => { void updateEditSessionDraft(value); }
              : undefined,
          lineNumbers: false,
          wordWrap: true,
          fontSize: 12,
        }),
        buildEditControls(EDIT_FIELDS.scriptSystemPrompt, interactionsLocked, hasEditSession, { allowResetToDefault: true }),
        text({ markdown: true, text: '**Task Prompt**' }),
        codeEditor({
          id: UI_IDS.scriptPromptEditor,
          language: 'plaintext',
          initialValue: scriptPromptEditorValue,
          height: CONFIG.promptEditorHeight,
          readOnly: runtime.storyGenerationActive || !isEditingField(EDIT_FIELDS.scriptPrompt),
          onChange: runtime.storyGenerationActive
            ? undefined
            : isEditingField(EDIT_FIELDS.scriptPrompt)
              ? (value) => { void updateEditSessionDraft(value); }
              : undefined,
          lineNumbers: false,
          wordWrap: true,
          fontSize: 12,
        }),
        buildEditControls(EDIT_FIELDS.scriptPrompt, interactionsLocked, hasEditSession, { allowResetToDefault: true }),
        text({ markdown: true, text: '**Preview**' }),
        codeEditor({
          id: 'sip-v2-script-panel-prompt-preview',
          language: 'plaintext',
          initialValue: getPromptViewerText(state),
          height: CONFIG.previewEditorHeight,
          readOnly: true,
          lineNumbers: false,
          wordWrap: true,
          fontSize: 12,
        }),
      ];
    } else if (currentTab === 'planning') {
      tabContent = [
        text({ markdown: true, text: '**Planning**' }),
        text({ text: 'Preview only. No live apply.' }),
        ...buildSourcePlanningParts(state, interactionsLocked, hasEditSession),
        text({ markdown: true, text: '**Targets**' }),
        text({ text: 'Preview lanes from committed canonical body.' }),
        ...buildRoutePlannerParts(state, interactionsLocked, hasEditSession),
      ];
    } else if (currentTab === 'history') {
      tabContent = [
        text({ markdown: true, text: '**History**' }),
                row({
          content: [
            button({
              id: UI_IDS.clearLogButton,
              text: 'Clear Log',
              disabled: interactionsLocked || hasEditSession,
              callback: async () => {
                await clearLog();
              },
            }),
          ],
        }),
        ...buildLogEntryParts(state, { showAll: true }),
      ];
    }

    return [
      container({
        style: {
          height: CONFIG.workspacePanelHeight,
          width: '100%',
          display: 'flex',
          flexDirection: 'column',
          overflowY: 'auto',
          overflowX: 'hidden',
          paddingRight: '4px',
          boxSizing: 'border-box',
        },
        content: [
          column({
            spacing: 'start',
            content: [
              text({ markdown: true, text: `**${CONFIG.sidebarName} Workspace**` }),
              text({ text: editNotice }),
              row({
                content: [
                  button({
                    id: UI_IDS.refreshButton,
                    text: runtime.busy ? 'Refreshing...' : (runtime.storyGenerationActive ? 'Turn Running...' : 'Refresh'),
                    disabled: interactionsLocked || hasEditSession,
                    callback: async () => {
                      await refreshSecretInfo('manual');
                    },
                  }),
                  checkboxInput({
                    id: UI_IDS.autoRefreshToggle,
                    initialValue: Boolean(state.autoRefreshEachTurn),
                    label: 'Auto refresh each turn',
                    disabled: interactionsLocked || hasEditSession,
                    onChange: async (value) => {
                      await setAutoRefreshEachTurn(value);
                    },
                  }),
                ],
              }),
              row({
                content: getWorkspaceTabOptions().map((tab) => button({
                  id: `sip-v2-workspace-tab-${tab.key}`,
                  text: currentTab === tab.key ? `[${tab.label}]` : tab.label,
                  disabled: hasEditSession && currentTab !== tab.key,
                  callback: async () => {
                    await setWorkspaceTab(tab.key);
                  },
                })),
              }),
              ...tabContent,
            ],
          }),
        ],
      }),
    ];
  }

  async function populateLogViewer() {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('using the log viewer.');
      return;
    }

    const latestState = await loadState();
    runtime.fullLogViewerText = buildLogText(latestState);
    await syncPanel(latestState);
  }

  async function clearLogViewer() {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('using the log viewer.');
      return;
    }

    const latestState = await loadState();
    runtime.fullLogViewerText = '';
    await syncPanel(latestState);
  }

  async function setRouteTargetEnabled(targetName, enabled) {
    if (!ROUTE_TARGET_NAMES.includes(targetName)) return;

    if (isPanelInteractionLocked()) {
      const state = await loadState();
      await syncPanel(state);
      await toastPanelLocked('changing route planning.');
      return;
    }

    if (hasActiveEditSession()) {
      const state = await loadState();
      await syncPanel(state);
      await api.v1.ui.toast('Save or cancel the current edit before changing route planning.');
      return;
    }

    let state = await loadState();
    const currentTarget = state.routedState?.targets?.[targetName];
    if (!currentTarget) return;
    if (Boolean(currentTarget.enabled) === Boolean(enabled)) {
      await syncPanel(state);
      return;
    }

    state.routedState.targets[targetName] = {
      ...currentTarget,
      enabled: Boolean(enabled),
      status: Boolean(enabled) ? 'preview-enabled' : ROUTE_LAYER_STATUS,
    };
    state.lastStatus = `${getRouteTargetLabel(targetName)} planning ${enabled ? 'enabled' : 'disabled'}.`;
    state.lastError = '';
    state = await saveState(state);
    await pushScriptLog('info', 'Updated route planner target.', `target=${targetName} enabled=${Boolean(enabled)}`);
    await syncPanel(state);
    await api.v1.ui.toast(`${getRouteTargetLabel(targetName)} planning ${enabled ? 'enabled' : 'disabled'}.`);
  }

  async function setLorebookOnlyCharacterDetection(enabled) {
    if (isPanelInteractionLocked()) {
      const state = await loadState();
      await syncPanel(state);
      await toastPanelLocked('changing source planning.');
      return;
    }

    if (hasActiveEditSession()) {
      const state = await loadState();
      await syncPanel(state);
      await api.v1.ui.toast('Save or cancel the current edit before changing source planning.');
      return;
    }

    let state = await loadState();
    const nextValue = Boolean(enabled);

    if (Boolean(state.lorebookOnlyCharacterDetection) === nextValue) {
      await syncPanel(state);
      return;
    }

    state.lorebookOnlyCharacterDetection = nextValue;
    state.lastStatus = nextValue
      ? 'Source planning set to lorebook-only discovery.'
      : 'Source planning set to prefer lorebooks with story-context fallback.';
    state.lastError = '';
    state = await saveState(state);
    await pushScriptLog('info', 'Updated source planning mode.', `lorebookOnlyCharacterDetection=${nextValue}`);
    await syncPanel(state);
    await api.v1.ui.toast(nextValue ? 'Lorebook-only source planning enabled.' : 'Story-context fallback restored.');
  }

  async function setAutoRefreshEachTurn(enabled) {
    if (isPanelInteractionLocked()) {
      const state = await loadState();
      await syncPanel(state);
      await toastPanelLocked('changing automatic updates.');
      return;
    }

    if (hasActiveEditSession()) {
      const state = await loadState();
      await syncPanel(state);
      await api.v1.ui.toast('Save or cancel the current edit before changing automatic updates.');
      return;
    }

    let state = await loadState();
    const nextValue = Boolean(enabled);

    if (Boolean(state.autoRefreshEachTurn) === nextValue) {
      await syncPanel(state);
      return;
    }

    state.autoRefreshEachTurn = nextValue;
    state.lastStatus = nextValue
      ? 'Auto refresh enabled. Secret info will refresh after successful story turns.'
      : 'Auto refresh disabled. Use Refresh to update secret info manually.';
    state.lastError = '';
    state = await saveState(state);
    await pushScriptLog('info', 'Updated auto-refresh mode.', `enabled=${nextValue}`);
    await syncPanel(state);
    await api.v1.ui.toast(nextValue ? 'Auto refresh enabled.' : 'Auto refresh disabled.');
  }

  async function syncPanel(state) {
    await loadEditSessionFromTemp();
    await loadWorkspaceTabFromTemp();
    const sidebarPanel = api.v1.ui.extension.sidebarPanel({
      id: UI_IDS.panel,
      name: `${CONFIG.sidebarName} v${CONFIG.scriptVersion}`,
      content: buildSidebarContent(state),
    });
    const scriptPanel = api.v1.ui.extension.scriptPanel({
      id: UI_IDS.scriptPanel,
      name: `${CONFIG.sidebarName} Workspace v${CONFIG.scriptVersion}`,
      content: buildScriptPanelContent(state),
    });
    await api.v1.ui.update([sidebarPanel, scriptPanel]);
  }

  // -----------------------------
  // Controller Module
  // -----------------------------
  async function refreshSecretInfo(source = 'manual', options = {}) {
    if (runtime.storyGenerationActive) {
      await pushScriptLog('warn', 'Refresh skipped because a story turn is still generating.', `source=${source}`);
      if (source !== 'auto') {
        await toastPanelLocked('refreshing.');
      }
      return;
    }

    if (hasActiveEditSession()) {
      await pushScriptLog('warn', 'Refresh skipped because an edit session is open.', `source=${source} field=${runtime.editSession.activeField}`);
      if (source !== 'auto') {
        await api.v1.ui.toast('Save or cancel the current edit before refreshing.');
      }
      return;
    }

    if (runtime.busy) {
      await pushScriptLog('warn', 'Refresh ignored because another refresh is already running.', `source=${source}`);
      if (source !== 'auto') {
        await api.v1.ui.toast('Secret Info refresh is already running.');
      }
      return;
    }

    runtime.busy = true;
    const previousDeferredLogPersistence = runtime.deferScriptLogPersistence;
    runtime.deferScriptLogPersistence = true;
    const refreshToken = `refresh-${Date.now()}-${runtime.nextRefreshToken++}`;
    const refreshStartedAt = formatTimestamp();
    const refreshSignal = await api.v1.createCancellationSignal();
    runtime.activeRefresh = {
      token: refreshToken,
      source,
      signal: refreshSignal,
      startedAt: refreshStartedAt,
      continuityId: sanitizeContinuityId(options.continuityId || ''),
      abortReason: '',
    };

    let panelState = null;

    try {
      await pushScriptLog('info', 'Refresh started.', `source=${source}`);
      let state = await loadState();
      state.lastStatus = `Running ${source} refresh...`;
      state.lastError = '';
      if (source === 'auto') {
        state = await setAutoRefreshActivity(state, {
          active: true,
          startedAt: refreshStartedAt,
          continuityId: runtime.activeRefresh.continuityId,
          source,
        });
      } else {
        state = await saveState(state);
      }
      panelState = state;
      await syncPanel(state);
      assertRefreshStillActive(refreshToken, 'story title load');

      const storyTitle = cleanInline(await api.v1.story.title.get());
      assertRefreshStillActive(refreshToken, 'story title load');
      await pushScriptLog('info', 'Loaded story title for refresh.', storyTitle || '(untitled story)');

      state.lastStoryTitle = storyTitle;
      state.lastModel = CONFIG.model;
      state = ensurePromptSeedForCurrentTurn(state);
      state = await saveState(state);
      panelState = state;
      assertRefreshStillActive(refreshToken, 'prompt preparation');

      const messages = parsePromptPreview(state.promptPreview);
      const safeMaxTokens = getSafeMaxTokens(CONFIG.maxTokens);
      if (!Number.isFinite(safeMaxTokens) || safeMaxTokens < CONFIG.minAllowedOutputTokens) {
        throw new Error('Not enough script output budget is currently available for a safe refresh.');
      }

      await pushScriptLog(
        'info',
        'Prepared generation prompt from rebuilt prompt preview.',
        `safeMaxTokens=${safeMaxTokens} storyTurnCounter=${sanitizeTurnCounter(state.storyTurnCounter)} promptSeedTurnCounter=${sanitizePromptSeedTurnCounter(state.promptSeedTurnCounter)}`
      );

      await pushScriptLog('info', 'Sending generateWithStory request.', `model=${CONFIG.model} temperature=${CONFIG.temperature}`);
      let response = await api.v1.generateWithStory(
        messages,
        {
          model: CONFIG.model,
          temperature: CONFIG.temperature,
          max_tokens: safeMaxTokens,
        },
        {
          suppressScriptHooks: 'self',
        },
        undefined,
        'background',
        refreshSignal
      );

      assertRefreshStillActive(refreshToken, 'response handling');
      let rawText = extractGeneratedTextRaw(response);
      let secretInfo = sanitizeSecretInfo(rawText);
      await pushScriptLog('info', 'Received model response.', `responseChars=${String(rawText || '').length}`);

      if (secretInfo && containsFirstPersonInnerVoice(secretInfo)) {
        await pushScriptLog('warn', 'First-person inner voice detected. Retrying in forced third person.');
        const retryMessages = [
          ...messages,
          {
            role: 'user',
            content: 'Rewrite the secret information block in close third person only. Do not use first-person pronouns or quoted inner monologue. Keep the same content and tone, but make the subject explicit enough that it cannot be mistaken for the story narrator or player POV.',
          },
        ];

        response = await api.v1.generateWithStory(
          retryMessages,
          {
            model: CONFIG.model,
            temperature: CONFIG.temperature,
            max_tokens: safeMaxTokens,
          },
          {
            suppressScriptHooks: 'self',
          },
          undefined,
          'background',
          refreshSignal
        );

        assertRefreshStillActive(refreshToken, 'retry response handling');
        rawText = extractGeneratedTextRaw(response);
        secretInfo = sanitizeSecretInfo(rawText);
        await pushScriptLog('info', 'Retry response received.', `responseChars=${String(rawText || '').length}`);
      }

      if (!secretInfo) {
        throw new Error('The model returned an empty secret-info block.');
      }

      if (containsFirstPersonInnerVoice(secretInfo)) {
        throw new Error('The model returned first-person inner voice after retry. Refresh again or tighten the prompt further.');
      }

      assertRefreshStillActive(refreshToken, 'state save');
      const updatedAt = formatTimestamp();
      const canonicalBody = sanitizeSecretInfoBody(secretInfo);
      state = commitRawDiagnosticOutput(
        state,
        preserveRawDiagnosticResponse(rawText),
        canonicalBody
      );
      state = commitCanonicalOutput(state, canonicalBody);
      state.lastUpdatedAt = updatedAt;
      state.lastModel = CONFIG.model;
      state.lastStoryTitle = storyTitle;
      state.lastStatus = 'Refresh complete.';
      state.lastError = '';
      state = appendLogEntry(state, {
        secretInfo,
        source,
        storyTitle,
        updatedAt,
      });
      if (source === 'auto') {
        state = await setAutoRefreshActivity(state, {
          active: false,
          startedAt: '',
          continuityId: '',
          source,
        });
      } else {
        state = await saveState(state);
      }
      panelState = state;
      await pushScriptLog('info', 'Saved refreshed secret info, rebuilt prompt preview, and appended history entry.', `sequence=${state.nextLogSequence - 1}`);
      await api.v1.ui.toast('Secret Info refreshed and logged.');
    } catch (err) {
      const isAborted = isRefreshAbortError(err) || Boolean(refreshSignal?.cancelled);
      const message = String(err?.message || err || (isAborted ? 'Refresh aborted.' : 'Unknown error'));
      let state = await loadState();
      if (isAborted) {
        state.lastStatus = source === 'auto'
          ? 'Auto refresh aborted in favor of a newer turn.'
          : 'Refresh aborted.';
        state.lastError = '';
        if (source === 'auto') {
          state = await setAutoRefreshActivity(state, {
            active: false,
            startedAt: '',
            continuityId: '',
            source,
          });
        } else {
          state = await saveState(state);
        }
        panelState = state;
      } else {
        state.lastStatus = 'Refresh failed.';
        state.lastError = message;
        if (source === 'auto') {
          state = await setAutoRefreshActivity(state, {
            active: false,
            startedAt: '',
            continuityId: '',
            source,
          });
        } else {
          state = await saveState(state);
        }
        panelState = state;
        await pushScriptLog('error', 'Refresh failed.', message);
        await api.v1.ui.toast(`Secret Info refresh failed: ${message}`);
      }
    } finally {
      if (runtime.activeRefresh?.token === refreshToken) {
        try {
          runtime.activeRefresh.signal?.dispose?.();
        } catch (_err) {
        }
        runtime.activeRefresh = null;
      }
      runtime.busy = false;
      runtime.deferScriptLogPersistence = previousDeferredLogPersistence;
      await flushScriptLogEntries();
      if (panelState) {
        await syncPanel(panelState);
      }
    }
  }

  async function clearSecretInfo() {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('clearing the saved block.');
      return;
    }
    if (hasActiveEditSession()) {
      await api.v1.ui.toast('Save or cancel the current edit before clearing the saved block.');
      return;
    }

    let state = await loadState();
    state = commitCanonicalOutput(state, '');
    state.promptSeedSecretInfo = '';
    state.promptSeedTurnCounter = -1;
    state.lastRawResponse = '';
    state.lastRawResponseBody = '';
    state.lastError = '';
    state.lastStatus = 'Cleared saved secret-info block.';
    state.lastUpdatedAt = '';
    state = await saveState(state);
    await pushScriptLog('info', 'Cleared saved secret-info block.');
    await syncPanel(state);
    await api.v1.ui.toast('Cleared saved secret-info block.');
  }

  async function clearLog() {
    if (isPanelInteractionLocked()) {
      await toastPanelLocked('clearing the history log.');
      return;
    }
    if (hasActiveEditSession()) {
      await api.v1.ui.toast('Save or cancel the current edit before clearing the history log.');
      return;
    }

    let state = await loadState();
    state.logEntries = [];
    state.nextLogSequence = 1;
    state.lastStatus = 'Cleared secret-info history log.';
    state.lastError = '';
    runtime.fullLogViewerText = '';
    state = await saveState(state);
    await pushScriptLog('info', 'Cleared secret-info history log.');
    await syncPanel(state);
    await api.v1.ui.toast('Cleared secret-info history log.');
  }

  api.v1.hooks.register('onResponse', (params) => {
    try {
      if (!params?.final) return;
      if (!params?.continuityId) return;
      runtime.completedContinuityIds.add(String(params.continuityId));
    } catch (_err) {
    }
  });

  api.v1.hooks.register('onGenerationRequested', async (params) => {
    try {
      const isTrackedStoryGeneration = shouldTrackStoryGeneration(params);

      if (isTrackedStoryGeneration) {
        runtime.storyGenerationActive = true;
        const state = await loadState();
        await syncPanel(state);
      }

      if (isTrackedStoryGeneration) {
        const aborted = await abortActiveAutoRefresh('Superseded by a newer user generation request.');
        if (aborted) {
          await api.v1.ui.toast('Discarded the previous Secret Info auto refresh for the newer turn.');
        }
      }
    } catch (err) {
      const message = String(err?.message || err || 'Unknown error');
      try {
        await pushScriptLog('error', 'Failed to cancel active auto refresh during generation request.', message);
      } catch (_) {
        api.v1.log(`[${CONFIG.scriptName}] Failed to cancel active auto refresh: ${message}`);
      }
    }
  });

  api.v1.hooks.register('onGenerationEnd', async (params) => {
    try {
      if (!params?.continuityId) return;
      if (params.inlineGeneration) return;
      if (params.toolboxMode) return;

      runtime.storyGenerationActive = false;

      const continuityId = String(params.continuityId);
      const sawFinalResponse = runtime.completedContinuityIds.has(continuityId);
      runtime.completedContinuityIds.delete(continuityId);

      if (!sawFinalResponse) {
        const state = await loadState();
        await syncPanel(state);
        return;
      }

      let state = await loadState();
      state.storyTurnCounter = sanitizeTurnCounter(state.storyTurnCounter) + 1;
      state = await saveState(state);
      await pushScriptLog('info', 'Observed completed story turn.', `continuityId=${continuityId} storyTurnCounter=${state.storyTurnCounter}`);

      if (!state.autoRefreshEachTurn) {
        await syncPanel(state);
        return;
      }

      if (hasActiveEditSession()) {
        state.lastStatus = `Auto refresh skipped because ${getEditFieldLabel(runtime.editSession.activeField)} is being edited.`;
        state.lastError = '';
        state = await saveState(state);
        await pushScriptLog('warn', 'Auto refresh skipped because an edit session is open.', `continuityId=${continuityId} field=${runtime.editSession.activeField}`);
        await syncPanel(state);
        return;
      }

      if (runtime.busy) {
        state.lastStatus = 'Auto refresh skipped because another refresh is still running.';
        state.lastError = '';
        state = await saveState(state);
        await pushScriptLog('warn', 'Auto refresh skipped because another refresh is still running.', `continuityId=${continuityId}`);
        await syncPanel(state);
        return;
      }

      await pushScriptLog('info', 'Auto refresh triggered after story generation.', `continuityId=${continuityId}`);
      await refreshSecretInfo('auto', { continuityId });
    } catch (err) {
      const message = String(err?.message || err);
      try {
        await pushScriptLog('error', 'Auto refresh hook failed.', message);
      } catch (_) {
        api.v1.log(`[${CONFIG.scriptName}] Auto refresh hook error: ${message}`);
      }
    }
  });

  api.v1.hooks.register('onScriptsLoaded', async () => {
    try {
      runtime.fullLogViewerText = '';
      runtime.completedContinuityIds.clear();
      await clearEditSession();
      await initializeFreshSession();
    } catch (err) {
      const message = String(err?.message || err);
      try {
        await pushScriptLog('error', 'onScriptsLoaded failed.', message);
      } catch (_) {
        api.v1.log(`[${CONFIG.scriptName}] onScriptsLoaded error: ${message}`);
      }
    }
  });
})();
