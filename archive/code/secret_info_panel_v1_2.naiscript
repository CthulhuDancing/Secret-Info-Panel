/*---
compatibilityVersion: naiscript-1.0
id: 3a9a3c73-6c39-4a57-8d67-4f1f5b6d9f22
name: Secret Info Panel
version: "0.2.0"
author: OpenAI
description: Fresh-start v1 plus persistent logging. Generates a compact private continuity block with GLM-4.6, shows it in a sidebar panel, and keeps a turn-by-turn log for testing. No Memory edits. No lorebook syncing.
memoryLimit: 8
---*/

(() => {
  const CONFIG = {
    scriptName: 'Secret Info Panel',
    scriptVersion: '0.2.0',
    model: 'glm-4-6',
    temperature: 0.7,
    maxTokens: 220,
    maxStoredChars: 2400,
    maxPriorChars: 1400,
    maxLogEntries: 30,
    minAllowedOutputTokens: 96,
    sidebarName: 'Secret Info',
  };

  const STORAGE_KEY = 'secret-info-panel-state-v2';

  const UI_IDS = {
    panel: 'sip-v2-panel',
    secretEditor: 'sip-v2-secret-editor',
    logEditor: 'sip-v2-log-editor',
    diagnosticsEditor: 'sip-v2-diagnostics-editor',
    refreshButton: 'sip-v2-refresh-button',
    clearButton: 'sip-v2-clear-button',
    clearLogButton: 'sip-v2-clear-log-button',
  };

  const runtime = {
    busy: false,
  };

  function createDefaultState() {
    return {
      secretInfo: '',
      lastUpdatedAt: '',
      lastModel: CONFIG.model,
      lastStatus: 'Idle. Press Refresh to generate a secret-info block from the current story context.',
      lastError: '',
      lastStoryTitle: '',
      lastPromptPreview: '',
      lastRawResponse: '',
      logEntries: [],
      nextLogSequence: 1,
    };
  }

  function cleanInline(value) {
    return String(value || '')
      .replace(/\r/g, '')
      .replace(/[ \t]+\n/g, '\n')
      .replace(/\n[ \t]+/g, '\n')
      .replace(/[ \t]{2,}/g, ' ')
      .trim();
  }

  function cleanParagraph(value) {
    return cleanInline(value)
      .replace(/\n{3,}/g, '\n\n')
      .trim();
  }

  function stripCodeFence(value) {
    return String(value || '')
      .replace(/^```[a-z0-9_-]*\s*/i, '')
      .replace(/\s*```$/i, '')
      .trim();
  }

  function clipText(value, maxChars) {
    const text = String(value || '').trim();
    if (!text) return '';
    if (!Number.isFinite(maxChars) || maxChars < 1 || text.length <= maxChars) return text;
    return text.slice(0, Math.max(0, maxChars - 1)).trimEnd() + '…';
  }

  function formatTimestamp(date = new Date()) {
    try {
      return date.toLocaleString();
    } catch (_err) {
      return new Date().toISOString();
    }
  }

  function sanitizeLogEntries(entries) {
    if (!Array.isArray(entries)) return [];
    return entries
      .filter((entry) => entry && typeof entry === 'object')
      .map((entry) => ({
        sequence: Number.isFinite(entry.sequence) ? Math.floor(entry.sequence) : 0,
        updatedAt: cleanInline(entry.updatedAt || ''),
        storyTitle: cleanInline(entry.storyTitle || ''),
        source: cleanInline(entry.source || 'manual'),
        changedFromPrevious: Boolean(entry.changedFromPrevious),
        secretInfo: clipText(cleanParagraph(entry.secretInfo || ''), CONFIG.maxStoredChars),
      }))
      .filter((entry) => entry.secretInfo)
      .slice(-CONFIG.maxLogEntries);
  }

  async function loadState() {
    const raw = await api.v1.storyStorage.get(STORAGE_KEY);
    if (!raw || typeof raw !== 'object') return createDefaultState();
    return {
      ...createDefaultState(),
      ...raw,
      logEntries: sanitizeLogEntries(raw.logEntries),
      nextLogSequence: Number.isFinite(raw.nextLogSequence) ? Math.max(1, Math.floor(raw.nextLogSequence)) : 1,
    };
  }

  async function saveState(state) {
    const safeState = {
      ...createDefaultState(),
      ...(state || {}),
      logEntries: sanitizeLogEntries(state?.logEntries),
      nextLogSequence: Number.isFinite(state?.nextLogSequence) ? Math.max(1, Math.floor(state.nextLogSequence)) : 1,
    };
    await api.v1.storyStorage.set(STORAGE_KEY, safeState);
  }

  function extractGeneratedText(response) {
    return cleanParagraph(
      response?.choices?.[0]?.text ??
      response?.choices?.[0]?.message?.content ??
      response?.text ??
      ''
    );
  }

  function sanitizeSecretInfo(rawText) {
    let text = cleanParagraph(stripCodeFence(rawText || ''));
    text = text.replace(/^secret\s+information\s*:\s*/i, '').trim();
    text = text.replace(/\s+/g, ' ').trim();

    if (!text) return '';
    text = clipText(text, CONFIG.maxStoredChars);

    return `Secret information: ${text}`;
  }

  function buildSystemPrompt() {
    return [
      'You create a private continuity note for the author of an ongoing fiction story.',
      'Your job is to infer hidden or semi-hidden character state from the current story context plus the previous secret-info block.',
      'Focus on private thoughts, unresolved intentions, shifting loyalties, attraction, suspicion, offscreen plans, concealed reactions, and likely near-term moves.',
      'This is not a public-facing summary and not a recap of obvious surface actions.',
      'Use only supported or strongly implied inferences.',
      'Do not invent large unseen events, world facts, or hard confirmations without support.',
      'Preserve useful carry-over from the previous secret-info block when it still fits.',
      'Revise or discard old assumptions when the current context contradicts them.',
      'Write one compact paragraph only.',
      'Begin exactly with: Secret information:',
      'Do not use markdown, bullet points, JSON, headings, or commentary about uncertainty.',
    ].join(' ');
  }

  function buildUserPrompt({ storyTitle, priorSecretInfo }) {
    const prior = clipText(cleanParagraph(priorSecretInfo || ''), CONFIG.maxPriorChars);

    return [
      storyTitle ? `Story title: ${storyTitle}` : '',
      prior
        ? `Previous secret-info block:\n${prior}`
        : 'Previous secret-info block:\n(none yet)',
      [
        'Update the private continuity note using the live story context already supplied by the editor.',
        'Prefer named characters who matter right now.',
        'Emphasize hidden motivations, internal reflections, subtext, private desires, strategy shifts, and offscreen consequences likely to matter soon.',
        'Avoid listing clothing, visible action beats, or broad world recap unless they directly matter to a hidden motive or plan.',
        'Target roughly 90 to 170 words.',
        'Return exactly one paragraph.',
      ].join(' '),
    ].filter(Boolean).join('\n\n');
  }

  function getSafeMaxTokens(requested) {
    const desired = Number.isFinite(requested) ? Math.floor(requested) : CONFIG.maxTokens;
    let safe = Math.max(CONFIG.minAllowedOutputTokens, desired);

    try {
      const allowed = api.v1.script?.getAllowedOutput?.();
      if (Number.isFinite(allowed) && allowed > 0) {
        safe = Math.min(safe, Math.floor(allowed));
      }
    } catch (_err) {
      // Ignore and use desired value.
    }

    return safe;
  }

  function appendLogEntry(state, { secretInfo, source, storyTitle, updatedAt }) {
    const entries = sanitizeLogEntries(state.logEntries);
    const previous = entries.length ? entries[entries.length - 1] : null;
    const entry = {
      sequence: Number.isFinite(state.nextLogSequence) ? Math.max(1, Math.floor(state.nextLogSequence)) : (entries.length + 1),
      updatedAt: cleanInline(updatedAt || formatTimestamp()),
      storyTitle: cleanInline(storyTitle || ''),
      source: cleanInline(source || 'manual'),
      changedFromPrevious: previous ? previous.secretInfo !== secretInfo : true,
      secretInfo: clipText(cleanParagraph(secretInfo || ''), CONFIG.maxStoredChars),
    };

    const nextEntries = [...entries, entry].slice(-CONFIG.maxLogEntries);
    return {
      ...state,
      logEntries: nextEntries,
      nextLogSequence: entry.sequence + 1,
    };
  }

  function buildLogText(state) {
    const entries = sanitizeLogEntries(state.logEntries);
    if (!entries.length) return 'No log entries yet. Refresh the panel after each turn to build a running history.';

    return entries
      .slice()
      .reverse()
      .map((entry) => {
        const header = [
          `Entry ${String(entry.sequence).padStart(3, '0')}`,
          entry.updatedAt || 'Unknown time',
          entry.source || 'manual',
          entry.changedFromPrevious ? 'changed' : 'unchanged',
        ].join(' | ');

        const lines = [header];
        if (entry.storyTitle) lines.push(`Story: ${entry.storyTitle}`);
        lines.push(entry.secretInfo || '(empty)');
        return lines.join('\n');
      })
      .join('\n\n────────────────────────────────────────\n\n');
  }

  function buildDiagnostics(state) {
    const entries = sanitizeLogEntries(state.logEntries);
    const lastEntry = entries.length ? entries[entries.length - 1] : null;

    const diagnostics = {
      model: state.lastModel || CONFIG.model,
      updatedAt: state.lastUpdatedAt || '',
      storyTitle: state.lastStoryTitle || '',
      busy: runtime.busy,
      hasSecretInfo: Boolean(cleanParagraph(state.secretInfo)),
      status: state.lastStatus || '',
      error: state.lastError || '',
      promptPreview: state.lastPromptPreview || '',
      rawResponsePreview: clipText(state.lastRawResponse || '', 600),
      logCount: entries.length,
      latestLogSequence: lastEntry?.sequence || 0,
      latestLogChanged: lastEntry ? Boolean(lastEntry.changedFromPrevious) : false,
    };
    return JSON.stringify(diagnostics, null, 2);
  }

  function buildPanelContent(state) {
    const { column, text, row, button, codeEditor } = api.v1.ui.part;
    const secretText = cleanParagraph(state.secretInfo) || 'No secret-info block has been generated yet.';
    const statusText = runtime.busy
      ? 'Refreshing secret info…'
      : (state.lastStatus || 'Idle.');

    return [
      column({
        spacing: 'start',
        content: [
          text({
            markdown: true,
            text: `**${CONFIG.sidebarName}**\n\nUses **GLM-4.6** plus the current story context and the last saved secret-info block. This v1 only displays the result here; it does not edit Memory.`,
          }),
          text({
            text: `Status: ${statusText}`,
          }),
          state.lastUpdatedAt
            ? text({ text: `Last updated: ${state.lastUpdatedAt}` })
            : text({ text: 'Last updated: —' }),
          row({
            content: [
              button({
                id: UI_IDS.refreshButton,
                text: runtime.busy ? 'Refreshing…' : 'Refresh',
                disabled: runtime.busy,
                callback: async () => {
                  await refreshSecretInfo('manual');
                },
              }),
              button({
                id: UI_IDS.clearButton,
                text: 'Clear Saved Block',
                disabled: runtime.busy,
                callback: async () => {
                  await clearSecretInfo();
                },
              }),
              button({
                id: UI_IDS.clearLogButton,
                text: 'Clear Log',
                disabled: runtime.busy,
                callback: async () => {
                  await clearLog();
                },
              }),
            ],
          }),
          codeEditor({
            id: UI_IDS.secretEditor,
            language: 'plaintext',
            initialValue: secretText,
            height: 280,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
          text({
            markdown: true,
            text: '**History Log**',
          }),
          codeEditor({
            id: UI_IDS.logEditor,
            language: 'plaintext',
            initialValue: buildLogText(state),
            height: 320,
            readOnly: true,
            lineNumbers: false,
            wordWrap: true,
            fontSize: 12,
          }),
          text({
            markdown: true,
            text: '**Diagnostics**',
          }),
          codeEditor({
            id: UI_IDS.diagnosticsEditor,
            language: 'json',
            initialValue: buildDiagnostics(state),
            height: 220,
            readOnly: true,
            lineNumbers: true,
            wordWrap: true,
            fontSize: 12,
          }),
        ],
      }),
    ];
  }

  async function syncPanel(state) {
    const panel = api.v1.ui.extension.sidebarPanel({
      id: UI_IDS.panel,
      name: `${CONFIG.sidebarName} v${CONFIG.scriptVersion}`,
      content: buildPanelContent(state),
    });
    await api.v1.ui.update([panel]);
  }

  async function refreshSecretInfo(source = 'manual') {
    if (runtime.busy) {
      await api.v1.ui.toast('Secret Info refresh is already running.');
      return;
    }

    runtime.busy = true;

    try {
      let state = await loadState();
      state.lastStatus = `Running ${source} refresh…`;
      state.lastError = '';
      await saveState(state);
      await syncPanel(state);

      const storyTitle = cleanInline(await api.v1.story.title.get());
      const messages = [
        {
          role: 'system',
          content: buildSystemPrompt(),
        },
        {
          role: 'user',
          content: buildUserPrompt({
            storyTitle,
            priorSecretInfo: state.secretInfo,
          }),
        },
      ];

      const safeMaxTokens = getSafeMaxTokens(CONFIG.maxTokens);
      if (!Number.isFinite(safeMaxTokens) || safeMaxTokens < CONFIG.minAllowedOutputTokens) {
        throw new Error('Not enough script output budget is currently available for a safe refresh.');
      }

      state.lastPromptPreview = messages
        .map((m) => `${m.role.toUpperCase()}: ${clipText(cleanParagraph(m.content), 800)}`)
        .join('\n\n');
      state.lastModel = CONFIG.model;
      state.lastStoryTitle = storyTitle;
      await saveState(state);
      await syncPanel(state);

      const response = await api.v1.generateWithStory(
        messages,
        {
          model: CONFIG.model,
          temperature: CONFIG.temperature,
          max_tokens: safeMaxTokens,
        },
        {
          suppressScriptHooks: 'self',
        },
        undefined,
        'background'
      );

      const rawText = extractGeneratedText(response);
      const secretInfo = sanitizeSecretInfo(rawText);

      if (!secretInfo) {
        throw new Error('The model returned an empty secret-info block.');
      }

      state = await loadState();
      const updatedAt = formatTimestamp();
      state.secretInfo = secretInfo;
      state.lastUpdatedAt = updatedAt;
      state.lastModel = CONFIG.model;
      state.lastStoryTitle = storyTitle;
      state.lastRawResponse = clipText(rawText, CONFIG.maxStoredChars);
      state.lastStatus = 'Refresh complete.';
      state.lastError = '';
      state = appendLogEntry(state, {
        secretInfo,
        source,
        storyTitle,
        updatedAt,
      });
      await saveState(state);
      await syncPanel(state);
      await api.v1.ui.toast('Secret Info refreshed and logged.');
    } catch (err) {
      const message = String(err?.message || err || 'Unknown error');
      const state = await loadState();
      state.lastStatus = 'Refresh failed.';
      state.lastError = message;
      await saveState(state);
      await syncPanel(state);
      await api.v1.ui.toast(`Secret Info refresh failed: ${message}`);
    } finally {
      runtime.busy = false;
      const state = await loadState();
      await syncPanel(state);
    }
  }

  async function clearSecretInfo() {
    if (runtime.busy) return;

    const state = await loadState();
    state.secretInfo = '';
    state.lastRawResponse = '';
    state.lastPromptPreview = '';
    state.lastError = '';
    state.lastStatus = 'Cleared saved secret-info block.';
    state.lastUpdatedAt = '';
    await saveState(state);
    await syncPanel(state);
    await api.v1.ui.toast('Cleared saved secret-info block.');
  }

  async function clearLog() {
    if (runtime.busy) return;

    const state = await loadState();
    state.logEntries = [];
    state.nextLogSequence = 1;
    state.lastStatus = 'Cleared secret-info history log.';
    state.lastError = '';
    await saveState(state);
    await syncPanel(state);
    await api.v1.ui.toast('Cleared secret-info history log.');
  }

  api.v1.hooks.register('onScriptsLoaded', async () => {
    try {
      const state = await loadState();
      await syncPanel(state);
      api.v1.log(`[${CONFIG.scriptName}] Loaded.`);
    } catch (err) {
      api.v1.log(`[${CONFIG.scriptName}] onScriptsLoaded error: ${String(err?.message || err)}`);
    }
  });
})();
